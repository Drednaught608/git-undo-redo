#!/usr/bin/env bash
# SPDX-License-Identifier: MIT-0

# =====================================================================
# THE ORTHOGONAL GIT HISTORY ENGINE (operation-level Undo/Redo)
# =====================================================================
#
# Appliance-style undo/redo for git, in the spirit of Jujutsu's operation
# log. `git undo` reverses your last HEAD-moving *operation* (commit, merge,
# rebase, reset, branch-switch checkout, whatever it was). Not "step back one
# commit in branch history": step back one *thing you did*.
#
# The operation log (oplog)
# -------------------------
# All tracking lives in an "orthogonal" space so it never pollutes (and is
# never read back from) git's own ref/reflog space:
#
#   * $GIT_DIR/git-undo-redo/timeline -> the oplog: one line per operation,
#         "<sha>\t<kind>\t<branch>", oldest first. This is what undo walks. The
#         branch (HEAD's ref at that state) lets undo land on the right branch
#         and recreate it if it was deleted; empty = unknown/detached.
#   * $GIT_DIR/git-undo-redo/cursor   -> 0-based index = where HEAD sits now.
#   * refs/git-undo-redo/keep/<sha>   -> one ref per state ever seen, so gc can
#         never reclaim an undone or abandoned state.
#
# Model
# -----
#   * seed : on first use the oplog is stitched from git's reflog (the record
#            of operations), with our own hops stripped. So even cold, the
#            first `git undo` reverses your last real operation.
#   * undo : move the cursor back one operation and restore that state on the
#            branch it was on (recreating that branch if it was deleted). Undoing
#            a branch-switch checkout just re-points HEAD; any other op moves the
#            branch's tip. A branch HEAD is never detached.
#   * redo : move the cursor forward again.
#   * APPEND-ONLY + PRIME ANCHORS: the oplog is never truncated. When you act
#            after having undone back to some point B, we append a prime marker
#            B' (a logical copy of B's state) and then your new op D:
#                oplog: [A, B, C, B', D]
#            so undo from D lands on B' (where you made the change) -> C
#            (preserved, never discarded) -> B -> A. Nothing is lost.
#
# The reflog is never read for navigation. The reset/checkout entries undo/redo
# leave behind are labeled (via GIT_REFLOG_ACTION) so a normal git user sees
# self-describing `git-undo`/`git-redo` lines, and we strip those back out.
# =====================================================================

set -u

# How many operations of pre-existing reflog history to stitch on first use.
OU_SEED_LIMIT=${OU_SEED_LIMIT:-100}

# Cached once per run by _ou_require_repo: the state dir and HEAD's sha. Caching is
# per-process only (a fresh process each command), so config/state changes are
# always picked up on the next invocation - nothing is persisted across runs.
_OU_SDIR=""
_OU_HEAD=""

# ---- internal helpers -----------------------------------------------

_ou_state_dir() {
    [ -n "${_OU_SDIR:-}" ] && { printf '%s' "$_OU_SDIR"; return 0; }
    local gd
    gd=$(git rev-parse --git-dir 2>/dev/null) || return 1
    printf '%s/git-undo-redo' "$gd"
}

_ou_require_repo() {
    # One git call gives both the git-dir (line 1) and HEAD's sha (line 2), and
    # fails if this isn't a repo with a valid HEAD. Caching both here avoids
    # re-spawning `git rev-parse` for the git-dir (used throughout) and for HEAD
    # (read by _ou_sync) on every call.
    local out
    out=$(git rev-parse --git-dir HEAD 2>/dev/null) || {
        echo "${C_ERR}❌ Error: Not a git repository or HEAD is invalid.${C_RESET}"
        return 1
    }
    _OU_SDIR="${out%%$'\n'*}/git-undo-redo"   # before first newline = git-dir
    _OU_HEAD="${out#*$'\n'}"                   # after first newline  = HEAD sha
}

# Refuse to clobber uncommitted work. Only tracked changes (staged/unstaged)
# are at risk; `git reset --hard`/`checkout` leave untracked files alone.
_ou_require_clean() {
    if [ -n "$(git status --porcelain --untracked-files=no 2>/dev/null)" ]; then
        echo "${C_ERR}❌ Error: You have uncommitted changes to tracked files.${C_RESET}"
        echo "   Commit or stash them first (undo/redo move HEAD)."
        return 1
    fi
}

_ou_head()    { printf '%s' "$_OU_HEAD"; }   # cached by _ou_require_repo (read before any HEAD move)
_ou_short()   { git log --oneline -1 "${1:-HEAD}" 2>/dev/null; }
_ou_headref() { git symbolic-ref -q HEAD 2>/dev/null || printf ''; }
_ou_branch()  { git symbolic-ref -q --short HEAD 2>/dev/null || printf ''; }

# Map a "checkout: moving from A to B" endpoint to a branch name, or "" when it
# is a commit (a detached checkout, e.g. "...to a1b2c3d"). Used by the seed to
# recover which branch each historical state belonged to.
_ou_branchname() {
    case "$1" in
        ''|*[!0-9a-fA-F]*) printf '%s' "$1" ;;                    # has a non-hex char: a name
        *) [ "${#1}" -ge 7 ] && printf '' || printf '%s' "$1" ;;  # all-hex and long: a sha
    esac
}

# Encode a branch name into a single filesystem-safe path component (branch names
# can contain '/'), reversibly enough to be collision-free.
_ou_enc() { local s="$1"; s="${s//%/%25}"; s="${s////%2F}"; printf '%s' "$s"; }

# Per-branch oplog directory for the current branch (under the orthogonal space).
_ou_local_dir() {
    local b; b="$(_ou_branch)"; [ -n "$b" ] || return 1
    printf '%s/local/%s' "$_OU_SDIR" "$(_ou_enc "$b")"
}

# User preferences, read once per run by _ou_load_config in a SINGLE git call for
# all undoredo.* keys (per-process cache, so a `git config` change is picked up on
# the next command - nothing is persisted). Flag overrides are applied by callers.
#   undoredo.default = global | local   (default global) - bare undo/redo/oplog/opstatus
#   undoredo.oplog   = full   | compact (default full)   - default git oplog view
#   undoredo.color   = auto   | always | never (default auto, color to a TTY)
OU_CFG_DEFAULT="" OU_CFG_OPLOG="" OU_CFG_COLOR=""
_ou_load_config() {
    local k v
    while read -r k v; do
        case "$k" in
            undoredo.default) OU_CFG_DEFAULT="$v" ;;
            undoredo.oplog)   OU_CFG_OPLOG="$v"   ;;
            undoredo.color)   OU_CFG_COLOR="$v"   ;;
        esac
    done < <(git config --get-regexp '^undoredo\.' 2>/dev/null)   # last value wins, like --get
}
_ou_cfg_default()       { case "$OU_CFG_DEFAULT" in local) printf 'local' ;; *) printf 'global' ;; esac; }
_ou_cfg_oplog_compact() { case "$OU_CFG_OPLOG"   in compact) printf '1' ;;   *) printf '0' ;;      esac; }

# Populate the C_* color vars (truecolor, palette from the landing page's terminal
# demo) from the cached undoredo.color. Honors NO_COLOR in auto mode. Leaving them
# empty makes every message plain, so piped/redirected output is byte-identical.
_ou_colors() {
    case "$OU_CFG_COLOR" in
        never)  return ;;
        always) ;;
        *)      { [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; } || return ;;
    esac
    local e=$'\033'
    C_RESET="$e[0m"
    C_UNDO="$e[38;2;255;111;156m"      # pink   #ff6f9c
    C_REDO="$e[38;2;142;123;255m"      # purple #8e7bff
    C_AT="$e[1;38;2;87;227;137m"       # green  #57e389 (bold)
    C_KIND="$e[38;2;245;196;81m"       # amber  #f5c451
    C_DIM="$e[38;2;154;157;180m"       # grey   #9a9db4
    C_MUTE="$e[38;2;126;130;152m"      # grey   #7e8298
    C_ERR="$e[38;2;255;82;119m"        # red    #ff5277
    C_OK="$e[38;2;87;227;137m"         # green  #57e389
}

# "1 commit" / "3 commits" -- naive pluralizer for human-facing messages.
_ou_qty() { if [ "$1" -eq 1 ]; then printf '%d %s' "$1" "$2"; else printf '%d %ss' "$1" "$2"; fi; }

# Protect a sha from garbage collection with its own keep-ref.
_ou_keep() { [ -n "$1" ] && git update-ref "refs/git-undo-redo/keep/$1" "$1" 2>/dev/null; }

# Batch-protect many shas in a single git call (fast cold-start seeding). The shas
# MUST be deduped first: `git update-ref --stdin` is one atomic transaction and
# aborts the WHOLE batch on a repeated ref ("multiple updates for ref ... not
# allowed"). A sha recurs non-consecutively in the reflog after any reset / amend /
# rebase / branch-switch, so without this dedup the entire keep-ref batch silently
# failed and seeding protected nothing from gc.
_ou_keep_all() {
    [ "$#" -gt 0 ] || return 0
    local s out=""; declare -A seen=()
    for s in "$@"; do
        [ -n "$s" ] || continue
        [ -n "${seen[$s]:-}" ] && continue
        seen["$s"]=1
        out+="update refs/git-undo-redo/keep/$s $s"$'\n'
    done
    [ -n "$out" ] || return 0
    printf '%s' "$out" | git update-ref --stdin 2>/dev/null
}

# Classify a reflog subject into an operation kind.
_ou_classify() {
    local s="$1"
    case "$s" in
        commit:*|"commit ("*) printf 'commit' ;;
        merge\ *|merge:*)      printf 'merge' ;;
        rebase*)               printf 'rebase' ;;
        cherry-pick*)          printf 'cherry-pick' ;;
        revert*)               printf 'revert' ;;
        am\ *|am:*)            printf 'am' ;;
        pull*)                 printf 'pull' ;;
        clone*)                printf 'clone' ;;
        reset:*)               printf 'reset' ;;
        checkout:*)            printf 'checkout' ;;
        git-undo:*)            printf 'undo' ;;
        git-redo:*)            printf 'redo' ;;
        *)                     printf '%s' "${s%%:*}" ;;
    esac
}

# Is a kind an "edit" (content-creating) op? Used by the per-branch log to know
# which entries are edits (e.g. when reconstructing prime anchors at seed).
_ou_is_edit() {
    case "$1" in
        commit|merge|rebase|cherry-pick|revert|am|pull|clone) return 0 ;;
        *) return 1 ;;
    esac
}

# ---- oplog state (globals) ------------------------------------------
# Parallel arrays loaded by _ou_load; CUR is the cursor index. TL_REF holds the
# branch HEAD was on at each state (empty = unknown/detached), used to restore
# onto the right branch and recreate it if it was deleted.
TL_SHA=()
TL_KIND=()
TL_REF=()
CUR=0
OU_LAST_KIND=""

# Selection->oplog-index map for `oplog --interactive`.
SEL_IDX=()

# Per-branch ("local") oplog state, loaded by _ou_local_load; LCUR is its cursor.
# This is a second, independent oplog per branch (its own edit history), used by
# `git undo --local` / `git redo --local`. It reuses the same cursor + prime model
# as the global oplog but tracks one branch's tip instead of HEAD.
LT_SHA=()
LT_KIND=()
LCUR=0

# ANSI colors (populated by _ou_colors; empty = no color so output stays plain
# when piped). Palette mirrors the landing page's terminal demo.
C_RESET="" C_UNDO="" C_REDO="" C_AT="" C_KIND="" C_DIM="" C_MUTE="" C_ERR="" C_OK=""

_ou_load() {
    local sdir sha kind
    sdir=$(_ou_state_dir) || return 1
    [ -f "$sdir/timeline" ] && [ -f "$sdir/cursor" ] || return 1
    TL_SHA=(); TL_KIND=(); TL_REF=()
    while IFS=$'\t' read -r sha kind ref; do
        [ -n "$sha" ] || continue
        TL_SHA+=("$sha"); TL_KIND+=("${kind:-other}"); TL_REF+=("${ref:-}")
    done < "$sdir/timeline"
    CUR=$(cat "$sdir/cursor")
    [ "${#TL_SHA[@]}" -gt 0 ] || return 1
}

_ou_save() {
    local sdir i
    sdir=$(_ou_state_dir) || return 1
    : > "$sdir/timeline"
    for (( i=0; i<${#TL_SHA[@]}; i++ )); do
        printf '%s\t%s\t%s\n' "${TL_SHA[i]}" "${TL_KIND[i]}" "${TL_REF[i]}"
    done >> "$sdir/timeline"
    printf '%s\n' "$CUR" > "$sdir/cursor"
}

# Compact, consistent meter from the loaded oplog, e.g. "(undo: 2 · redo: 1)".
_ou_meter() {
    local last=$(( ${#TL_SHA[@]} - 1 ))
    printf '%s(undo: %d · redo: %d)%s' "$C_DIM" "$CUR" "$(( last - CUR ))" "$C_RESET"
}

# Restore HEAD to a recorded state ($2=sha) on its recorded branch ($3=ref): switch
# to that branch (if needed) and reset it to the sha. EVERY entry restores to its own
# sha, checkout edges included, so the cursor always matches HEAD. If the branch was
# deleted we recreate it at the recorded commit and land on it; a branch HEAD is never
# detached. Returns non-zero (without claiming success) if the reset fails - e.g. the
# commit is missing because it predates gc protection.
#
# Our own HEAD moves are labeled - the reset via GIT_REFLOG_ACTION, the branch
# switch via `symbolic-ref -m "<action>: ..."` - so the seed strips both back out
# and never re-ingests them as user operations.
#
# When ref is empty (a cold/legacy entry whose branch we couldn't determine, or a
# state that was detached) we fall back to a heuristic that still never detaches.
# $1=op-kind $2=sha $3=ref. OU_ACTION labels the reflog entries.
_ou_restore() {
    local kind="$1" sha="$2" ref="$3" action="${OU_ACTION:-git-undo}"
    if [ -z "$ref" ]; then
        _ou_restore_heuristic "$kind" "$sha" "$action"
        return
    fi
    if git show-ref --verify --quiet "refs/heads/$ref"; then
        # Restore the entry's snapshot: switch to its branch (if needed), then reset
        # that branch to the entry's recorded sha. EVERY entry restores to its own
        # sha, checkout edges included - so the cursor always matches HEAD. (A checkout
        # that kept the live tip instead left HEAD != the entry's sha, which desynced
        # the cursor and made the next sync record a phantom change.)
        [ "$(_ou_branch)" = "$ref" ] || \
            git symbolic-ref -m "$action: switch branch" HEAD "refs/heads/$ref" 2>/dev/null
        GIT_REFLOG_ACTION="$action" git reset --hard "$sha" >/dev/null 2>&1
    else
        # Branch was deleted: recreate it at the recorded commit and land on it.
        git update-ref "refs/heads/$ref" "$sha" 2>/dev/null
        git symbolic-ref -m "$action: restore branch" HEAD "refs/heads/$ref" 2>/dev/null
        GIT_REFLOG_ACTION="$action" git reset --hard "$sha" >/dev/null 2>&1
    fi
}

# Fallback restore for entries with no recorded branch (cold/legacy/detached):
# switch to a branch sitting at the sha when reversing a checkout, otherwise reset
# the current branch. Never detaches unless HEAD was already detached.
_ou_restore_heuristic() {
    local kind="$1" sha="$2" action="$3" b
    if [ "$kind" = "checkout" ]; then
        b=$(git for-each-ref --points-at "$sha" --format='%(refname:short)' refs/heads/ 2>/dev/null | head -n1)
        if [ -n "$b" ]; then
            [ "$(_ou_branch)" = "$b" ] || \
                git symbolic-ref -m "$action: switch branch" HEAD "refs/heads/$b" 2>/dev/null
            GIT_REFLOG_ACTION="$action" git reset --hard "$b" >/dev/null 2>&1
            return
        fi
    fi
    if [ -n "$(_ou_headref)" ]; then
        GIT_REFLOG_ACTION="$action" git reset --hard "$sha" >/dev/null 2>&1
    else
        git checkout --quiet --detach "$sha" 2>/dev/null \
            || GIT_REFLOG_ACTION="$action" git reset --hard "$sha" >/dev/null 2>&1
    fi
}

# First use: stitch the oplog from git's reflog (the operation record), newest
# first, with our own hops stripped and consecutive dupes collapsed, capped to
# the newest OU_SEED_LIMIT, then laid down oldest-first. Cursor = HEAD.
#
# We also recover which branch each historical state was on by reading the
# reflog's "checkout: moving from A to B" messages as we walk newest->oldest:
# the newest entry is the branch HEAD is on now, and each checkout tells us the
# entries older than it were on its "from" branch. (Branch tracking is updated
# from every entry, even ones we strip or dedup, so a same-commit branch switch
# still moves the tracked branch.)
_ou_seed() {
    local sdir sha subj kind prev="" i curbranch entry_branch rest from to
    local shas=() kinds=() refs=() hops=()
    sdir=$(_ou_state_dir) || return 1
    mkdir -p "$sdir"

    curbranch=$(_ou_branch)
    while IFS=$'\t' read -r sha subj; do
        [ -n "$sha" ] || continue
        entry_branch="$curbranch"
        case "$subj" in
            "checkout: moving from "*)
                rest=${subj#checkout: moving from }
                from=${rest% to *}; to=${rest##* to }
                entry_branch=$(_ou_branchname "$to")
                curbranch=$(_ou_branchname "$from")
                ;;
        esac
        case "$subj" in
            '') continue ;;
            git-undo:*|git-redo:*|git-recover:*)
                # Our own hop (see _ou_local_seed): flag the kept entry just newer
                # than it so prime reconstruction below fires only for real hops.
                [ "${#shas[@]}" -gt 0 ] && hops[$(( ${#shas[@]} - 1 ))]=1
                continue ;;
        esac
        [ "$sha" = "$prev" ] && continue
        prev="$sha"
        kind=$(_ou_classify "$subj")
        shas+=("$sha"); kinds+=("${kind:-other}"); refs+=("$entry_branch"); hops+=(0)
        [ "${#shas[@]}" -ge "$OU_SEED_LIMIT" ] && break
    done < <(git reflog --format='%H%x09%gs' 2>/dev/null)

    if [ "${#shas[@]}" -eq 0 ]; then
        echo "${C_ERR}❌ Error: No history to seed from.${C_RESET}"
        return 1
    fi

    TL_SHA=(); TL_KIND=(); TL_REF=(); local TL_HOP=()
    for (( i=${#shas[@]}-1; i>=0; i-- )); do
        TL_SHA+=("${shas[i]}"); TL_KIND+=("${kinds[i]}"); TL_REF+=("${refs[i]}"); TL_HOP+=("${hops[i]:-0}")
    done

    # Reconstruct prime anchors from our stripped hops - the same label-driven rule
    # as _ou_local_seed, but carrying branch attribution. Without this, a tool undo
    # done before the global log was first seeded (e.g. a local-first workflow, which
    # still labels HEAD's reflog) would land a later global undo on the abandoned
    # commit instead of the prime. The prime takes the edit's branch.
    if [ "${#TL_SHA[@]}" -gt 1 ]; then
        local h p; local rs=() rk=() rr=(); declare -A _par _present
        while read -r h p _; do _par["$h"]="$p"; done \
            < <(git log --no-walk=unsorted --format='%H %P' "${TL_SHA[@]}" 2>/dev/null)
        for (( i=0; i<${#TL_SHA[@]}; i++ )); do
            h="${TL_SHA[i]}"; p="${_par[$h]:-}"
            if [ "${TL_HOP[i]:-0}" = 1 ] && _ou_is_edit "${TL_KIND[i]}" && [ -n "$p" ] \
               && [ "${#rs[@]}" -gt 0 ] && [ "${rs[$(( ${#rs[@]} - 1 ))]}" != "$p" ] \
               && [ -n "${_present[$p]:-}" ]; then
                rs+=("$p"); rk+=("prime"); rr+=("${TL_REF[i]}")
            fi
            rs+=("$h"); rk+=("${TL_KIND[i]}"); rr+=("${TL_REF[i]}"); _present["$h"]=1
        done
        TL_SHA=("${rs[@]}"); TL_KIND=("${rk[@]}"); TL_REF=("${rr[@]}")
    fi

    _ou_keep_all "${shas[@]}"          # one git call, not one per state
    CUR=$(( ${#TL_SHA[@]} - 1 ))
    # Anchor the cursor on the actual HEAD: it may not be the newest seeded state
    # if an earlier tool hop (stripped from the reflog) moved HEAD back.
    local hn hi
    hn=$(_ou_head)
    for (( hi=${#TL_SHA[@]}-1; hi>=0; hi-- )); do
        [ "${TL_SHA[hi]}" = "$hn" ] && { CUR=$hi; break; }
    done
    _ou_save
}

# Reconcile the oplog with the real HEAD before any operation. The ONLY place
# external changes enter the model, by comparing HEAD to where we parked the
# cursor (never by reading the reflog for navigation). A new op is appended;
# if it happened after undoing back, a prime anchor is inserted first.
_ou_sync() {
    local head parked
    head=$(_ou_head) || return 1
    if ! _ou_load; then
        _ou_seed || return 1
        return 0
    fi

    parked="${TL_SHA[$CUR]}"
    [ "$head" = "$parked" ] && return 0   # nothing happened since we parked

    local last sha kind curref
    last=$(( ${#TL_SHA[@]} - 1 ))
    curref=$(_ou_branch)                  # branch HEAD is on now (empty if detached)

    # Acted after undoing back: anchor a prime of where we were, so undo from
    # the new op lands there and the path we undid past is preserved.
    if [ "$CUR" -lt "$last" ]; then
        TL_SHA+=("$parked"); TL_KIND+=("prime"); TL_REF+=("${TL_REF[$CUR]}")
    fi

    # The most recent HEAD op (reflog top) decides how to record this change.
    kind=$(_ou_classify "$(git reflog -1 --format='%gs' 2>/dev/null)")
    if git merge-base --is-ancestor "$parked" "$head" 2>/dev/null; then
        if [ "$kind" = "commit" ] || [ -z "$kind" ]; then
            # Commits made between runs: stitch EACH as its own op, so undo steps
            # through them one at a time - even if several happened between runs.
            while IFS= read -r sha; do
                [ -n "$sha" ] || continue
                TL_SHA+=("$sha"); TL_KIND+=("commit"); TL_REF+=("$curref")
                _ou_keep "$sha"
            done < <(git rev-list --reverse --first-parent "$parked..$head" 2>/dev/null)
        else
            # A single non-commit move to a descendant (a branch switch, ff-merge, or
            # rebase): record it as that one op, not as commits you never authored.
            TL_SHA+=("$head"); TL_KIND+=("$kind"); TL_REF+=("$curref")
            _ou_keep "$head"
        fi
    else
        # Divergent move (reset / rebase / checkout to a non-descendant): one op.
        TL_SHA+=("$head"); TL_KIND+=("${kind:-other}"); TL_REF+=("$curref")
        _ou_keep "$head"
    fi

    CUR=$(( ${#TL_SHA[@]} - 1 ))
    _ou_save
}

# Restore the entry at index $1 (one snapshot reset) and move the cursor there.
# $2 = reflog action label. The single-step primitive used by _ou_walk.
_ou_goto() {
    local target="$1"
    # Restore FIRST; only advance the cursor if it succeeded. A failed reset (e.g. the
    # object was reclaimed by gc on a pre-fix repo) must NOT report success or move the
    # cursor - that would desync the cursor from HEAD and lie about "nothing is lost".
    OU_ACTION="${2:-git-undo}" _ou_restore "${TL_KIND[$target]}" "${TL_SHA[$target]}" "${TL_REF[$target]}" || return 1
    CUR="$target"
    printf '%s\n' "$CUR" > "$(_ou_state_dir)/cursor"
}

# Walk the global cursor from where it is to index $1, ONE entry at a time, so every
# intermediate operation is faithfully reversed/reapplied - a branch switch en route
# recreates/repoints that branch, exactly as stepping by hand would. The global log
# is an *operation* log, so `git undo 3` must equal three `git undo`s (and the `-i`
# picker is just the visual form of the same walk). Local jumps instead (no branch
# entries, so a jump is identical) - see _ou_local_goto.
_ou_walk() {
    local target="$1"
    while [ "$CUR" -gt "$target" ]; do _ou_goto $(( CUR - 1 )) git-undo || return 1; done
    while [ "$CUR" -lt "$target" ]; do _ou_goto $(( CUR + 1 )) git-redo || return 1; done
}

# Shown when a restore aborts because the target commit is no longer in the repo.
_ou_restore_failed() {
    echo "${C_ERR}❌ Could not restore that state: its commit is missing from the repository" >&2
    echo "   (likely reclaimed by gc before this version protected it). HEAD is at $(_ou_short).${C_RESET}" >&2
}

# `--staged`: after navigating to a landing point, stage the full diff of commit $1
# (the entry directly above the landing) onto the working tree WITHOUT moving HEAD -
# i.e. leave that commit's changes uncommitted-but-staged, ready to edit and re-commit.
# `git restore` touches only the index + worktree (no reflog, no branch move), and
# handles additions, modifications, and deletions.
_ou_stage_apply() {
    git restore --source="$1" --staged --worktree :/ 2>/dev/null
}

# Echo the commit directly above <sha> in <branch>'s LOCAL edit log (loaded fresh,
# seeded from the branch reflog if there's no log yet - never navigated). Returns 1
# if the branch is unknown/detached, <sha> isn't in its log, or it's at the top.
# A branch reflog holds only that branch's own tip-moves (never a checkout), so any
# entry above a point is always a takeable commit - which is exactly why global
# --staged consults this instead of the global timeline: a global op whose log
# neighbor is a checkout can still stage when the landing branch has a commit above.
# Mutates LT_* (the caller must not rely on them afterward).
_ou_above_commit() {
    local branch="$1" sha="$2" d i pos=-1
    [ -n "$branch" ] || return 1
    d="$_OU_SDIR/local/$(_ou_enc "$branch")"
    _ou_local_load "$d" || _ou_local_seed "$d" "$branch" || return 1
    for (( i=${#LT_SHA[@]}-1; i>=0; i-- )); do
        [ "${LT_SHA[i]}" = "$sha" ] && { pos=$i; break; }
    done
    [ "$pos" -ge 0 ] && [ "$pos" -lt $(( ${#LT_SHA[@]} - 1 )) ] || return 1
    printf '%s\n' "${LT_SHA[$(( pos + 1 ))]}"
}

# Error for --staged when the landing branch's edit log shows no commit above.
_ou_stage_none() {
    echo "${C_ERR}❌ --staged needs a commit directly above where you'd land on branch ${1:-?},${C_RESET}" >&2
    echo "   ${C_ERR}but its edit log shows none. Drop --staged to move normally.${C_RESET}" >&2
    return 1
}

# ---- per-branch ("local") oplog -------------------------------------
# A second oplog per branch, holding that branch's own edit history. It uses the
# same cursor + prime-anchor model as the global oplog, but tracks the branch tip
# instead of HEAD and restores by resetting that branch (we're always on it, so
# it never switches or detaches). Seeded once from the branch's own reflog - which
# IS that branch's edit history - with our labeled hops stripped. The global and
# local oplogs are independent; each absorbs the other's effects via its own sync.

_ou_local_load() {
    local d="$1" sha kind
    [ -f "$d/timeline" ] && [ -f "$d/cursor" ] || return 1
    LT_SHA=(); LT_KIND=()
    while IFS=$'\t' read -r sha kind; do
        [ -n "$sha" ] || continue
        LT_SHA+=("$sha"); LT_KIND+=("${kind:-other}")
    done < "$d/timeline"
    LCUR=$(cat "$d/cursor")
    [ "${#LT_SHA[@]}" -gt 0 ] || return 1
}

_ou_local_save() {
    local d="$1" i
    mkdir -p "$d"
    : > "$d/timeline"
    for (( i=0; i<${#LT_SHA[@]}; i++ )); do
        printf '%s\t%s\n' "${LT_SHA[i]}" "${LT_KIND[i]}"
    done >> "$d/timeline"
    printf '%s\n' "$LCUR" > "$d/cursor"
}

_ou_local_meter() {
    local last=$(( ${#LT_SHA[@]} - 1 ))
    printf '%s(undo: %d · redo: %d)%s' "$C_DIM" "$LCUR" "$(( last - LCUR ))" "$C_RESET"
}

# Seed a branch's oplog from its reflog (its edit history), newest-first, our hops
# stripped and consecutive dupes collapsed, then laid down oldest-first.
_ou_local_seed() {
    local d="$1" branch="$2" sha subj kind prev="" i
    local shas=() kinds=() hops=()
    mkdir -p "$d"
    while IFS=$'\t' read -r sha subj; do
        [ -n "$sha" ] || continue
        case "$subj" in
            '') continue ;;
            git-undo:*|git-redo:*|git-recover:*)
                # Our own hop. It's stripped from the seeded log, but it is the ONLY
                # thing that can have created a prime (an undo-then-reapply done
                # before this log existed). Flag the kept entry just newer than it -
                # the edit made right after the hop - so prime reconstruction below
                # considers real hops only, never ordinary commits/merges/resets.
                [ "${#shas[@]}" -gt 0 ] && hops[$(( ${#shas[@]} - 1 ))]=1
                continue ;;
        esac
        [ "$sha" = "$prev" ] && continue
        prev="$sha"
        kind=$(_ou_classify "$subj")
        shas+=("$sha"); kinds+=("${kind:-other}"); hops+=(0)
        [ "${#shas[@]}" -ge "$OU_SEED_LIMIT" ] && break
    done < <(git reflog show "$branch" --format='%H%x09%gs' 2>/dev/null)

    [ "${#shas[@]}" -gt 0 ] || { echo "${C_ERR}❌ Error: $branch has no edit history to seed from.${C_RESET}" >&2; return 1; }
    LT_SHA=(); LT_KIND=(); local LT_HOP=()
    for (( i=${#shas[@]}-1; i>=0; i-- )); do
        LT_SHA+=("${shas[i]}"); LT_KIND+=("${kinds[i]}"); LT_HOP+=("${hops[i]:-0}")
    done

    # Reconstruct prime anchors the cold seed can't see directly. A prime can only
    # be born from one of OUR hops (an undo-then-reapply): a manual `git reset` back
    # leaves an ordinary, unstripped reflog entry that anchors itself, and a normal
    # commit/merge/fast-forward abandons nothing. So we reconstruct ONLY for entries
    # flagged above as following a stripped git-undo/redo hop - never from the
    # topology of unmarked history (which is what made merges look like primes). For
    # such an entry, if it attached to an earlier recorded state that isn't its
    # predecessor (the path we undid past), anchor that parent before it.
    if [ "${#LT_SHA[@]}" -gt 1 ]; then
        local h p; local rs=() rk=(); declare -A _par _present
        while read -r h p _; do _par["$h"]="$p"; done \
            < <(git log --no-walk=unsorted --format='%H %P' "${LT_SHA[@]}" 2>/dev/null)
        for (( i=0; i<${#LT_SHA[@]}; i++ )); do
            h="${LT_SHA[i]}"; p="${_par[$h]:-}"
            if [ "${LT_HOP[i]:-0}" = 1 ] && _ou_is_edit "${LT_KIND[i]}" && [ -n "$p" ] \
               && [ "${#rs[@]}" -gt 0 ] && [ "${rs[$(( ${#rs[@]} - 1 ))]}" != "$p" ] \
               && [ -n "${_present[$p]:-}" ]; then
                rs+=("$p"); rk+=("prime")
            fi
            rs+=("$h"); rk+=("${LT_KIND[i]}"); _present["$h"]=1
        done
        LT_SHA=("${rs[@]}"); LT_KIND=("${rk[@]}")
    fi

    _ou_keep_all "${shas[@]}"
    LCUR=$(( ${#LT_SHA[@]} - 1 ))
    # Anchor on the actual branch tip (it may not be the newest seeded state if a
    # tool hop, stripped from the reflog, moved the branch back).
    local tn ti
    tn=$(git rev-parse --verify "refs/heads/$branch" 2>/dev/null)
    for (( ti=${#LT_SHA[@]}-1; ti>=0; ti-- )); do
        [ "${LT_SHA[ti]}" = "$tn" ] && { LCUR=$ti; break; }
    done
    _ou_local_save "$d"
}

# Reconcile a branch's oplog with its current tip (same model as _ou_sync).
_ou_local_sync() {
    local d="$1" branch="$2" tip parked last sha kind j
    tip=$(git rev-parse --verify "refs/heads/$branch" 2>/dev/null) || return 1
    if ! _ou_local_load "$d"; then
        _ou_local_seed "$d" "$branch" || return 1
        return 0
    fi
    parked="${LT_SHA[$LCUR]}"
    [ "$tip" = "$parked" ] && return 0

    # A cross-scope tool hop (e.g. a global undo/redo) navigates this branch and
    # leaves one of OUR labels on top of its reflog. A branch reflog holds only
    # this branch's own tip-moves, so that label unambiguously marks navigation,
    # not a new edit. If it landed on a state already in this log, just reposition
    # the cursor (as the seed does) instead of re-recording the hop as a redundant
    # op. (The global log, by design, still records every op - we don't touch it.)
    case "$(git reflog show "$branch" -1 --format='%gs' 2>/dev/null)" in
        git-undo:*|git-redo:*|git-recover:*)
            for (( j=${#LT_SHA[@]}-1; j>=0; j-- )); do
                [ "${LT_SHA[j]}" = "$tip" ] || continue
                LCUR=$j; printf '%s\n' "$LCUR" > "$d/cursor"; return 0
            done
            ;;
    esac

    last=$(( ${#LT_SHA[@]} - 1 ))
    if [ "$LCUR" -lt "$last" ]; then
        LT_SHA+=("$parked"); LT_KIND+=("prime")
    fi
    kind=$(_ou_classify "$(git reflog show "$branch" -1 --format='%gs' 2>/dev/null)")
    if git merge-base --is-ancestor "$parked" "$tip" 2>/dev/null; then
        if [ "$kind" = "commit" ] || [ -z "$kind" ]; then
            while IFS= read -r sha; do
                [ -n "$sha" ] || continue
                LT_SHA+=("$sha"); LT_KIND+=("commit")
                _ou_keep "$sha"
            done < <(git rev-list --reverse --first-parent "$parked..$tip" 2>/dev/null)
        else
            # ff-merge / rebase forward on this branch: one op, not authored commits.
            LT_SHA+=("$tip"); LT_KIND+=("$kind")
            _ou_keep "$tip"
        fi
    else
        LT_SHA+=("$tip"); LT_KIND+=("${kind:-other}")
        _ou_keep "$tip"
    fi
    LCUR=$(( ${#LT_SHA[@]} - 1 ))
    _ou_local_save "$d"
}

# Restore a branch state: just reset the current branch (we're always on it for a
# local op, so this never switches branches or detaches).
_ou_local_restore() {
    GIT_REFLOG_ACTION="${OU_ACTION:-git-undo}" git reset --hard "$1" >/dev/null 2>&1
}

# Move the per-branch cursor to index $2 and restore that entry (single reset, same
# single-snapshot model as _ou_goto). $1 = state dir, $3 = reflog action label.
_ou_local_goto() {
    local d="$1"
    OU_ACTION="${3:-git-undo}" _ou_local_restore "${LT_SHA[$2]}" || return 1   # don't advance on a failed reset
    LCUR="$2"
    printf '%s\n' "$LCUR" > "$d/cursor"
}

# `git undo [N]` (global): step back N operations (default 1). Refuses, changing
# nothing, if N exceeds the number available.
_ou_undo_global() {
    local count="${1:-1}" staged="${2:-0}" avail
    _ou_require_clean || return 1
    _ou_sync          || return 1
    avail=$CUR
    if [ "$avail" -le 0 ]; then
        echo "${C_ERR}🛑 Nothing to undo globally: already at the oldest recorded state.${C_RESET}"
        return 0
    fi
    if [ "$count" -gt "$avail" ]; then
        echo "${C_ERR}🛑 Only $(_ou_qty "$avail" step) available to undo globally; you asked for $count. Nothing changed.${C_RESET}"
        return 1
    fi
    if [ "$staged" = 1 ]; then
        # The commit to stage is decided by the LANDING branch's own edit log, not
        # the global timeline - so undoing a checkout (whose global neighbor isn't a
        # commit) still stages when that branch shows a commit directly above.
        local target=$(( CUR - count )) above odisp="${TL_KIND[$CUR]}"
        [ "$odisp" = prime ] && odisp="$(_ou_prime_kind "$CUR")′"
        above="$(_ou_above_commit "${TL_REF[$target]}" "${TL_SHA[$target]}")" \
            || { _ou_stage_none "${TL_REF[$target]}"; return 1; }
        _ou_walk "$target" || { _ou_restore_failed; return 1; }
        _ou_stage_apply "$above"
        if [ "$count" -eq 1 ]; then echo "${C_UNDO}↶ Undo ($odisp) →${C_RESET} $(_ou_short)  $(_ou_meter)"
        else echo "${C_UNDO}↶ Undo $count operations →${C_RESET} $(_ou_short)  $(_ou_meter)"; fi
        echo "   ${C_OK}↥ staged the changes from $(_ou_short "$above")${C_RESET} - edit and re-commit"
        return 0
    fi
    local start=$CUR odisp="${TL_KIND[$CUR]}"     # the op reversed - for the N=1 message
    [ "$odisp" = prime ] && odisp="$(_ou_prime_kind "$start")′"   # a prime shows as e.g. commit′
    _ou_walk $(( CUR - count )) || { _ou_restore_failed; return 1; }   # walk every point: undo N == N undos
    if [ "$count" -eq 1 ]; then
        echo "${C_UNDO}↶ Undo ($odisp) →${C_RESET} $(_ou_short)  $(_ou_meter)"
    else
        echo "${C_UNDO}↶ Undo $count operations →${C_RESET} $(_ou_short)  $(_ou_meter)"
    fi
}

# `git redo [N]` (global): step forward N operations (default 1).
_ou_redo_global() {
    local count="${1:-1}" staged="${2:-0}" last avail
    _ou_require_clean || return 1
    _ou_sync          || return 1
    last=$(( ${#TL_SHA[@]} - 1 ))
    avail=$(( last - CUR ))
    if [ "$avail" -le 0 ]; then
        echo "${C_ERR}🛑 Nothing to redo globally: already at the most recent state.${C_RESET}"
        return 0
    fi
    if [ "$count" -gt "$avail" ]; then
        echo "${C_ERR}🛑 Only $(_ou_qty "$avail" step) available to redo globally; you asked for $count. Nothing changed.${C_RESET}"
        return 1
    fi
    if [ "$staged" = 1 ]; then
        # As with undo: the staged commit comes from the landing branch's edit log.
        local target=$(( CUR + count )) above
        above="$(_ou_above_commit "${TL_REF[$target]}" "${TL_SHA[$target]}")" \
            || { _ou_stage_none "${TL_REF[$target]}"; return 1; }
        _ou_walk "$target" || { _ou_restore_failed; return 1; }
        _ou_stage_apply "$above"
        if [ "$count" -eq 1 ]; then
            local rdisp="${TL_KIND[$CUR]}"; [ "$rdisp" = prime ] && rdisp="$(_ou_prime_kind "$CUR")′"
            echo "${C_REDO}↷ Redo ($rdisp) →${C_RESET} $(_ou_short)  $(_ou_meter)"
        else echo "${C_REDO}↷ Redo $count operations →${C_RESET} $(_ou_short)  $(_ou_meter)"; fi
        echo "   ${C_OK}↥ staged the changes from $(_ou_short "$above")${C_RESET} - edit and re-commit"
        return 0
    fi
    _ou_walk $(( CUR + count )) || { _ou_restore_failed; return 1; }   # walk every point: redo N == N redos
    if [ "$count" -eq 1 ]; then
        local rdisp="${TL_KIND[$CUR]}"            # the op re-applied (the entry we moved to)
        [ "$rdisp" = prime ] && rdisp="$(_ou_prime_kind "$CUR")′"   # a prime shows as e.g. commit′
        echo "${C_REDO}↷ Redo ($rdisp) →${C_RESET} $(_ou_short)  $(_ou_meter)"
    else
        echo "${C_REDO}↷ Redo $count operations →${C_RESET} $(_ou_short)  $(_ou_meter)"
    fi
}

# `git undo --local [N]`: step back N edits on the current branch (default 1).
_ou_undo_local() {
    local count="${1:-1}" staged="${2:-0}" d branch avail
    branch="$(_ou_branch)"
    if [ -z "$branch" ]; then
        echo "${C_ERR}❌ Local undo needs a branch, but HEAD is detached.${C_RESET}"
        echo "   Run 'git undo --global' to undo your last operation instead."
        return 1
    fi
    _ou_require_clean || return 1
    d=$(_ou_local_dir)            || return 1
    _ou_local_sync "$d" "$branch" || return 1
    avail=$LCUR
    if [ "$avail" -le 0 ]; then
        echo "${C_ERR}🛑 Nothing to undo on branch $branch: already at its oldest edit.${C_RESET}"
        return 0
    fi
    if [ "$count" -gt "$avail" ]; then
        echo "${C_ERR}🛑 Only $(_ou_qty "$avail" edit) available to undo on branch $branch; you asked for $count. Nothing changed.${C_RESET}"
        return 1
    fi
    if [ "$staged" = 1 ]; then
        # Same take logic as everywhere: stage the entry directly above the landing
        # in this branch's local log (always a takeable commit). Undoing always has
        # one above, but keep the guard uniform with redo/global.
        local target=$(( LCUR - count )) lst=$(( ${#LT_SHA[@]} - 1 )) above
        [ $(( target + 1 )) -le "$lst" ] || { _ou_stage_none "$branch"; return 1; }
        above="${LT_SHA[$(( target + 1 ))]}"
        _ou_local_goto "$d" "$target" git-undo || { _ou_restore_failed; return 1; }
        _ou_stage_apply "$above"
        if [ "$count" -eq 1 ]; then echo "${C_UNDO}↶ Undo edit on ${C_RESET}${C_REDO}$branch${C_RESET}${C_UNDO} →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
        else echo "${C_UNDO}↶ Undo $count edits on ${C_RESET}${C_REDO}$branch${C_RESET}${C_UNDO} →${C_RESET} $(_ou_short)  $(_ou_local_meter)"; fi
        echo "   ${C_OK}↥ staged the changes from $(_ou_short "$above")${C_RESET} - edit and re-commit"
        return 0
    fi
    _ou_local_goto "$d" $(( LCUR - count )) git-undo || { _ou_restore_failed; return 1; }   # one jump, not N resets
    if [ "$count" -eq 1 ]; then
        echo "${C_UNDO}↶ Undo edit on ${C_RESET}${C_REDO}$branch${C_RESET}${C_UNDO} →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
    else
        echo "${C_UNDO}↶ Undo $count edits on ${C_RESET}${C_REDO}$branch${C_RESET}${C_UNDO} →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
    fi
}

# `git redo --local [N]`: step forward N edits on the current branch (default 1).
_ou_redo_local() {
    local count="${1:-1}" staged="${2:-0}" d branch last avail
    branch="$(_ou_branch)"
    if [ -z "$branch" ]; then
        echo "${C_ERR}❌ Local redo needs a branch, but HEAD is detached.${C_RESET}"
        echo "   Run 'git redo --global' to redo your last operation instead."
        return 1
    fi
    _ou_require_clean || return 1
    d=$(_ou_local_dir)            || return 1
    _ou_local_sync "$d" "$branch" || return 1
    last=$(( ${#LT_SHA[@]} - 1 ))
    avail=$(( last - LCUR ))
    if [ "$avail" -le 0 ]; then
        echo "${C_ERR}🛑 Nothing to redo on branch $branch: already at its most recent edit.${C_RESET}"
        return 0
    fi
    if [ "$count" -gt "$avail" ]; then
        echo "${C_ERR}🛑 Only $(_ou_qty "$avail" edit) available to redo on branch $branch; you asked for $count. Nothing changed.${C_RESET}"
        return 1
    fi
    if [ "$staged" = 1 ]; then
        # Same take logic: stage the entry directly above the landing (none above
        # when you redo to the top - that's the only local case that fails).
        local target=$(( LCUR + count )) above
        [ $(( target + 1 )) -le "$last" ] || { _ou_stage_none "$branch"; return 1; }
        above="${LT_SHA[$(( target + 1 ))]}"
        _ou_local_goto "$d" "$target" git-redo || { _ou_restore_failed; return 1; }
        _ou_stage_apply "$above"
        if [ "$count" -eq 1 ]; then echo "${C_REDO}↷ Redo edit on $branch →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
        else echo "${C_REDO}↷ Redo $count edits on $branch →${C_RESET} $(_ou_short)  $(_ou_local_meter)"; fi
        echo "   ${C_OK}↥ staged the changes from $(_ou_short "$above")${C_RESET} - edit and re-commit"
        return 0
    fi
    _ou_local_goto "$d" $(( LCUR + count )) git-redo || { _ou_restore_failed; return 1; }   # one jump, not N resets
    if [ "$count" -eq 1 ]; then
        echo "${C_REDO}↷ Redo edit on $branch →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
    else
        echo "${C_REDO}↷ Redo $count edits on $branch →${C_RESET} $(_ou_short)  $(_ou_local_meter)"
    fi
}

# `git take [N]`: stage the changes from the commit N entries above the current
# point (default 1), reading THIS branch's edit log. It never moves HEAD or the
# cursor - it only copies that commit's files onto the worktree and stages them
# (via _ou_stage_apply). The "I undid and forgot --staged" fix, plus the ability
# (no undo/redo equivalent) to reach further up with N. Always edit-based.
_ou_take() {
    local count="${1:-1}" branch d last avail above
    branch="$(_ou_branch)"
    if [ -z "$branch" ]; then
        echo "${C_ERR}❌ git take needs a branch, but HEAD is detached.${C_RESET}"
        echo "   It stages a commit from this branch's edit log; check out a branch first."
        return 1
    fi
    _ou_require_clean || return 1
    d=$(_ou_local_dir)            || return 1
    _ou_local_sync "$d" "$branch" || return 1
    last=$(( ${#LT_SHA[@]} - 1 ))
    avail=$(( last - LCUR ))
    if [ "$avail" -le 0 ]; then
        echo "${C_ERR}🛑 Nothing above the current point on branch $branch to take.${C_RESET}"
        echo "   ${C_DIM}'git take' grabs a commit you've moved below - e.g. right after 'git undo'.${C_RESET}"
        return 0
    fi
    if [ "$count" -gt "$avail" ]; then
        echo "${C_ERR}🛑 Only $(_ou_qty "$avail" commit) above current on branch $branch; you asked for $count. Nothing changed.${C_RESET}"
        return 1
    fi
    above="${LT_SHA[$(( LCUR + count ))]}"
    if ! _ou_stage_apply "$above"; then
        echo "${C_ERR}❌ Could not stage from $(_ou_short "$above") - is the commit still present?${C_RESET}" >&2
        return 1
    fi
    echo "${C_OK}↥ Took the changes from $(_ou_short "$above")${C_RESET} - staged onto $(_ou_short), edit and commit."
}

# ---- help text ------------------------------------------------------

_ou_usage() {
    cat <<'EOF'
git undo/redo - operation-level undo/redo for git, tracked in an orthogonal oplog.

Subcommands (install as git-undo, git-redo, git-oplog, git-opstatus, git-take on PATH):
  git undo        Reverse your last operation (commit, merge, rebase, reset,
                  branch switch). Add -l to undo the last edit on this branch.
  git redo        Re-apply an operation (or edit) you undid.
  git oplog       Show the operation log.
  git opstatus    Show where you are and how many undo/redo steps remain.
  git take        Copy a commit's changes into your files and stage them, without
                  moving HEAD - the fix for "I undid but forgot --staged." Reads
                  this branch's log; 'git take N' takes the Nth commit above you.

Run any subcommand with -h for details. (git reserves '--help' for its own manual
pages, so `git undo --help` looks for a man page, not this text - use -h here.)

Notes:
  * Undo/redo need a clean working tree (untracked files are fine).
  * `git undo N` / `git redo N` do N at once; they refuse (changing nothing) if N
    is more than available, and tell you how many there are.
  * The oplog is append-only - undoing then acting never loses history.
  * Global (-g, default) walks the shared operation log; local (-l) walks the
    current branch's own edits. Set the default with `git config undoredo.default`
    (global|local), the oplog view with `git config undoredo.oplog` (full|compact),
    and color with `git config undoredo.color` (auto|always|never).
EOF
}

_ou_help_undo() {
    cat <<'EOF'
git undo - reverse your last operation (global) or last edit on this branch (local).

Usage: git undo [N] [-g|--global | -l|--local] [-i|--interactive] [-h]

Global (default): steps back one operation in the shared operation log - commit,
merge, rebase, reset, or branch switch. You land back on the branch that op was
on (recreated if you'd deleted it); it never detaches HEAD.

Local (-l): steps back one *edit* on the branch you're currently on, using that
branch's own log. It stays on your branch and moves only its tip - so you can
switch to any branch and undo its last edit without being pulled elsewhere.

Pass a number N to undo that many at once (e.g. `git undo 3`). If N is more than
are available it refuses, changing nothing, and tells you how many there are.

With neither flag, the default is set by `git config undoredo.default`
(global|local; default global). Requires a clean working tree; untracked files
are fine.

Options:
  N                 Undo N steps at once (default 1).
  -g, --global      Undo one operation in the shared log (default).
  -l, --local       Undo the last edit on the current branch.
  -s, --staged      Land as usual, but leave the commit directly above you STAGED
                    (uncommitted) instead of removing its changes - the "I committed
                    too early, let me edit and re-commit" flow. Fails if there's no
                    commit directly above where you land.
  -i, --interactive Open the picker for the chosen scope (global, or local with
                    -l; otherwise follows undoredo.default) and drop straight to a
                    point you choose ('t' toggles prime anchors). Like 'git oplog -i'.
  -h                Show this help. (git owns '--help' - 'git undo --help' goes to
                    git's manual lookup, not here; -h is the help flag.)

At the oldest tracked point, undo stops. Anything older lives in git's own
reflog (`git reflog`), your durable backstop.
EOF
}

_ou_help_redo() {
    cat <<'EOF'
git redo - re-apply an operation (global) or an edit on this branch (local) you undid.

Usage: git redo [N] [-g|--global | -l|--local] [-i|--interactive] [-h]

Re-applies what you undid: global (default) steps forward in the shared
operation log; local (-l) steps forward through the current branch's own edits.
Pass a number N to redo that many at once (e.g. `git redo 2`); it refuses,
changing nothing, if N is more than are available. The default with neither flag
is set by `git config undoredo.default`. Acting after undoing never discards what
you undid past, so redo is available until you perform a new operation. Requires
a clean working tree.

Options:
  N                 Redo N steps at once (default 1).
  -g, --global      Redo one operation in the shared log (default).
  -l, --local       Redo the last undone edit on the current branch.
  -s, --staged      Land as usual, but leave the commit directly above you STAGED
                    (uncommitted) rather than re-committed. Fails if there's no
                    commit directly above where you land.
  -i, --interactive Open the picker for the chosen scope (global, or local with
                    -l; otherwise follows undoredo.default) and drop straight to a
                    point you choose ('t' toggles prime anchors). Like 'git oplog -i'.
  -h                Show this help. (git owns '--help' - 'git redo --help' goes to
                    git's manual lookup, not here; -h is the help flag.)
EOF
}

_ou_help_oplog() {
    cat <<'EOF'
git oplog - show the operation log (global) or a branch's edit log (local).

Usage: git oplog [-g|--global | -l|--local] [-c|--compact | -f|--full]
                 [-i|--interactive] [--reset] [-h]

Lists every tracked entry (oldest at the bottom), each tagged with its kind,
with your current position marked '@'. The log is append-only: when you act after
undoing, a prime anchor of the state you resumed from is inserted first, so nothing
you undid past is ever lost. A prime shows as that op's kind with a prime mark, e.g.
'commit′' / 'checkout′'.

Scope:
  -g, --global      Show the shared operation log (default).
  -l, --local       Show the current branch's own edit log.
                    With neither, follows `git config undoredo.default`.

Views:
  -f, --full        Show every entry, including prime anchors (default).
  -c, --compact     Hide prime anchors for a cleaner list.
  -i, --interactive Show the log and drop straight to a point you pick (combine
                    with -g/-l and -c/-f; press 't' in the picker to toggle the
                    view). A cursor move, not a new operation. Also reachable as
                    'git undo -i' / 'git redo -i', which honor -g/-l the same way.

The default view (full or compact) can be set with `git config undoredo.oplog`.

Other:
      --reset   Drop the tracked oplog (global timeline + cursor, per-branch logs,
                keep-refs) so it rebuilds cleanly from git's reflog on the next
                command. A rebuild, not a wipe: recent history stitches back in;
                what's dropped is accumulated tracking older than the reflog, prime
                anchors, and any wedged state. Your commits and files are untouched.
                Long form only, by design.
  -h            Show this help. (git owns '--help' - 'git oplog --help' goes to
                git's manual lookup, not here; -h is the help flag.)
EOF
}

_ou_help_opstatus() {
    cat <<'EOF'
git opstatus - show where you are and how many undo/redo steps remain.

Usage: git opstatus [-g|--global | -l|--local] [-h]

Prints the current HEAD and how many undo and redo steps are available, for the
shared operation log (global, the default) or the current branch's edit log
(local). With neither flag, follows `git config undoredo.default`.

Options:
  -g, --global   Count steps in the shared operation log (default).
  -l, --local    Count edit steps on the current branch.
  -h             Show this help. (git owns '--help' - 'git opstatus --help' goes
                 to git's manual lookup, not here; -h is the help flag.)
EOF
}

_ou_help_take() {
    cat <<'EOF'
git take - stage the changes from a commit above your current point.

Usage: git take [N] [-h]

Grabs a commit from THIS branch's edit log that sits above where you are now,
copies its files onto your working tree, and stages them - without moving HEAD.
It's the "I undid and forgot --staged" fix: run 'git take' and the commit you
just undid past is staged, ready to edit and re-commit.

Unlike undo/redo, take never moves you - it only stages. It is always edit-based,
reading the current branch's own log (the same one 'git oplog -l' shows), so N
counts entries above your position there. It also goes where the --staged flag
can't: 'git take N' reaches several commits up in one shot. Requires a clean
working tree and a branch (not a detached HEAD). Refuses, changing nothing, if
there aren't N commits above you.

Options:
  N             Take the commit N entries above current (default 1, directly above).
  -h            Show this help. (git owns '--help' - 'git take --help' goes to
                git's manual lookup, not here; -h is the help flag.)
EOF
}

# ---- public commands ------------------------------------------------

# Expand bundled single-dash short flags so `-ls` parses as `-l -s`. Only a token
# that is a dash followed by two-or-more letters AND nothing but letters is split
# (so long `--flags`, a single `-l`, a bare number, and `-l3` are left untouched -
# the last stays "unknown", since a count is a separate arg: `git undo -l 3`).
# Each dispatcher runs its args through this before parsing:
#   local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
_ou_unbundle() {
    local a body
    for a in "$@"; do
        case "$a" in
            -[A-Za-z][A-Za-z]*)
                body="${a#-}"
                case "$body" in
                    *[!A-Za-z]*) printf '%s\n' "$a" ;;   # has a non-letter: leave as-is
                    *) while [ -n "$body" ]; do printf -- '-%s\n' "${body:0:1}"; body="${body:1}"; done ;;
                esac ;;
            *) printf '%s\n' "$a" ;;
        esac
    done
}

git-undo() {
    local mode="" interactive=0 count=1 staged=0
    local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)        _ou_help_undo; return 0 ;;
            -l|--local)       mode=local ;;
            -g|--global)      mode=global ;;
            -i|--interactive) interactive=1 ;;
            -s|--staged)      staged=1 ;;
            *)  case "$1" in
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_undo >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many to undo
                esac ;;
        esac
        shift
    done
    _ou_require_repo  || return 1
    [ -z "$mode" ] && mode=$(_ou_cfg_default)

    if [ "$interactive" -eq 1 ]; then
        _ou_show "$mode" "$(_ou_cfg_oplog_compact)" 1   # picker honors -g/-l/default (--staged not applicable)
        return $?
    fi
    [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to undo (0 requested).${C_RESET}"; return 0; }

    if [ "$mode" = "local" ]; then _ou_undo_local "$count" "$staged"; else _ou_undo_global "$count" "$staged"; fi
}

git-redo() {
    local mode="" interactive=0 count=1 staged=0
    local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)        _ou_help_redo; return 0 ;;
            -l|--local)       mode=local ;;
            -g|--global)      mode=global ;;
            -i|--interactive) interactive=1 ;;
            -s|--staged)      staged=1 ;;
            *)  case "$1" in
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_redo >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many to redo
                esac ;;
        esac
        shift
    done
    _ou_require_repo  || return 1
    [ -z "$mode" ] && mode=$(_ou_cfg_default)

    if [ "$interactive" -eq 1 ]; then
        _ou_show "$mode" "$(_ou_cfg_oplog_compact)" 1   # picker honors -g/-l/default (--staged not applicable)
        return $?
    fi
    [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to redo (0 requested).${C_RESET}"; return 0; }

    if [ "$mode" = "local" ]; then _ou_redo_local "$count" "$staged"; else _ou_redo_global "$count" "$staged"; fi
}

git-take() {
    local count=1
    local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) _ou_help_take; return 0 ;;
            *)  case "$1" in
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_take >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many entries up to take from
                esac ;;
        esac
        shift
    done
    _ou_require_repo || return 1
    [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to take (0 requested).${C_RESET}"; return 0; }
    _ou_take "$count"
}

git-undo-status() {
    local mode="" branch d last
    local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)   _ou_help_opstatus; return 0 ;;
            -g|--global) mode=global ;;
            -l|--local)  mode=local ;;
            *)           echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_opstatus >&2; return 2 ;;
        esac
        shift
    done
    _ou_require_repo || return 1
    [ -z "$mode" ] && mode=$(_ou_cfg_default)   # neither flag: follow undoredo.default

    if [ "$mode" = "local" ]; then
        branch=$(_ou_branch)
        if [ -z "$branch" ]; then
            echo "${C_ERR}❌ Local status is per-branch, but HEAD is detached.${C_RESET}"
            echo "   Use 'git opstatus --global' for the shared operation log."
            return 1
        fi
        d=$(_ou_local_dir)            || return 1
        _ou_local_sync "$d" "$branch" || return 1
        last=$(( ${#LT_SHA[@]} - 1 ))
        echo "${C_MUTE}On branch${C_RESET} ${C_REDO}$branch${C_RESET}${C_MUTE}, HEAD is at:${C_RESET} $(_ou_short)"
        if [ "$LCUR" -eq 0 ] && [ "$last" -eq 0 ]; then
            echo "${C_DIM}No edits to undo or redo on $branch yet.${C_RESET}"
        else
            echo "${C_MUTE}Available on this branch${C_RESET} $(_ou_local_meter)"
        fi
    else
        _ou_sync || return 1
        last=$(( ${#TL_SHA[@]} - 1 ))
        echo "${C_MUTE}HEAD is at:${C_RESET} $(_ou_short)"
        if [ "$CUR" -eq 0 ] && [ "$last" -eq 0 ]; then
            echo "${C_DIM}Nothing to undo or redo globally yet - this is the only tracked state.${C_RESET}"
        else
            echo "${C_MUTE}Available globally${C_RESET} $(_ou_meter)"
        fi
    fi
}

# A prime anchor is shown as its underlying operation kind plus a prime mark, e.g.
# "commit′" / "checkout′" - the op you resumed from, marked as the resume point (not
# the bare word "prime"). The underlying kind is the real entry sharing the prime's
# sha. $1 = index into TL_SHA/TL_KIND; echoes the bare kind (callers append the ′).
_ou_prime_kind() {
    local i="$1" sha="${TL_SHA[$1]}" j
    for (( j=0; j<${#TL_SHA[@]}; j++ )); do
        if [ "$j" -ne "$i" ] && [ "${TL_SHA[j]}" = "$sha" ] && [ "${TL_KIND[j]}" != prime ]; then
            printf '%s' "${TL_KIND[j]}"; return 0
        fi
    done
    printf 'commit'   # fallback: the real entry isn't in view (shouldn't happen)
}

# Print the oplog (reads TL_SHA/TL_KIND/CUR, so the caller loads whichever log to
# show). $1=compact (hide prime rows except the cursor's); $2=numbered (prepend
# 1..N selection numbers and fill SEL_IDX, for interactive pick); $3=title.
_ou_oplog_print() {
    local compact="$1" numbered="$2" title="${3:-Global operation log}" i kind mark n=0 h u rest
    SEL_IDX=()

    # Resolve "<shortsha> <subject>" for every distinct sha in chunked batches
    # (one `git log` per ~256 shas) instead of one `git log` per row, so
    # printing stays fast even on a long, fully-retained oplog.
    declare -A SUBJ seen
    local batch=()
    for h in "${TL_SHA[@]}"; do
        [ -n "${seen[$h]:-}" ] && continue
        seen["$h"]=1
        batch+=("$h")
        if [ "${#batch[@]}" -ge 256 ]; then
            while IFS=$'\t' read -r u rest; do SUBJ["$u"]="$rest"; done \
                < <(git log --no-walk=unsorted --format='%H%x09%h %s' "${batch[@]}" 2>/dev/null)
            batch=()
        fi
    done
    if [ "${#batch[@]}" -gt 0 ]; then
        while IFS=$'\t' read -r u rest; do SUBJ["$u"]="$rest"; done \
            < <(git log --no-walk=unsorted --format='%H%x09%h %s' "${batch[@]}" 2>/dev/null)
    fi

    echo "$title ${C_MUTE}(newest first; @ = current position)${C_RESET}:"
    local pad="         " kpad kcol mark subj uk   # pad = 9 spaces (kind column width)
    for (( i=${#TL_SHA[@]}-1; i>=0; i-- )); do
        kind="${TL_KIND[i]}"
        if [ "$compact" -eq 1 ] && [ "$kind" = "prime" ] && [ "$i" -ne "$CUR" ]; then
            continue
        fi
        # @ marks the cursor (green); kind is pink at the cursor, purple for a
        # prime anchor, amber otherwise - matching the landing page's demo.
        if [ "$i" -eq "$CUR" ]; then mark=" ${C_AT}@${C_RESET}"; kcol="$C_UNDO"
        elif [ "$kind" = "prime" ];  then mark="  "; kcol="$C_REDO"
        else                              mark="  "; kcol="$C_KIND"; fi
        if [ "$kind" = "prime" ]; then             # show the resumed-from op, e.g. commit′
            uk="$(_ou_prime_kind "$i")"; kpad="$uk′${pad:$(( ${#uk} + 1 ))}"
        else
            kpad="$kind${pad:${#kind}}"            # left-justify to 9 (no color in the width)
        fi
        subj="${SUBJ[${TL_SHA[i]}]:-${TL_SHA[i]:0:7}}"
        if [ "$numbered" -eq 1 ]; then
            n=$(( n + 1 )); SEL_IDX+=("$i")
            printf '%s %2d) %s%s%s %s\n' "$mark" "$n" "$kcol" "$kpad" "$C_RESET" "$subj"
        else
            printf '%s %3d  %s%s%s %s\n' "$mark" "$i" "$kcol" "$kpad" "$C_RESET" "$subj"
        fi
    done
}

# Interactive: show the oplog and drop straight to a chosen point. A cursor move
# (restores the state, never detaches), not a new operation. $1=initial view
# (0=full / 1=compact, toggleable in-session with 't'); $2=scope (global|local;
# decides how the jump is applied and saved); $3=title. The caller has already
# loaded the chosen log into TL_SHA/TL_KIND/CUR.
_ou_oplog_interactive() {
    local compact="$1" scope="${2:-global}" title="${3:-Global operation log}" choice idx
    while :; do
        _ou_oplog_print "$compact" 1 "$title"
        if [ ! -t 0 ]; then
            echo
            echo "${C_ERR}Not a terminal - re-run interactively to pick a point.${C_RESET}" >&2
            return 2
        fi
        read -r -p "${C_DIM}Drop to 1-${#SEL_IDX[@]}  ·  [t] toggle full/compact  ·  [q] quit:${C_RESET} " choice
        case "$choice" in
            t|T)         [ "$compact" -eq 1 ] && compact=0 || compact=1; echo; continue ;;
            q|Q|"")      echo "${C_DIM}Cancelled.${C_RESET}"; return 0 ;;
            *[!0-9]*)    echo "${C_DIM}Invalid selection.${C_RESET}"; echo; continue ;;
        esac
        if [ "$choice" -lt 1 ] || [ "$choice" -gt "${#SEL_IDX[@]}" ]; then
            echo "${C_DIM}Out of range.${C_RESET}"; echo; continue
        fi
        idx="${SEL_IDX[$((choice - 1))]}"
        break
    done
    [ "$idx" -eq "$CUR" ] && { echo "${C_DIM}Already here.${C_RESET}"; return 0; }
    _ou_require_clean || return 1
    if [ "$scope" = "local" ]; then
        OU_ACTION="git-undo" _ou_local_restore "${TL_SHA[$idx]}" || { _ou_restore_failed; return 1; }
        CUR="$idx"                                          # local: jump straight there
        printf '%s\n' "$idx" > "$(_ou_local_dir)/cursor"   # timeline unchanged; move cursor only
    else
        _ou_walk "$idx" || { _ou_restore_failed; return 1; }   # global: walk every point to it
    fi
    echo "${C_OK}→ Dropped to${C_RESET} $(_ou_short)  $(_ou_meter)"
}

# Show a log for a scope: print it, or (interactive) open the picker. $1=mode
# (global|local), $2=compact (0/1 initial view), $3=interactive (0/1). Loads the
# chosen log into TL_SHA/TL_KIND/CUR. Shared by `git oplog`, `git undo -i`, and
# `git redo -i` so all three honor -g/-l and undoredo.default identically.
_ou_show() {
    local mode="$1" compact="$2" interactive="$3" branch d
    if [ "$mode" = "local" ]; then
        branch=$(_ou_branch)
        if [ -z "$branch" ]; then
            echo "${C_ERR}❌ The local log is per-branch, but HEAD is detached.${C_RESET}"
            echo "   Use a global view instead (e.g. 'git oplog --global')."
            return 1
        fi
        d=$(_ou_local_dir)            || return 1
        _ou_local_sync "$d" "$branch" || return 1
        [ "${#LT_SHA[@]}" -gt 0 ] || { echo "${C_DIM}No edits recorded for $branch yet.${C_RESET}"; return 0; }
        TL_SHA=("${LT_SHA[@]}"); TL_KIND=("${LT_KIND[@]}"); TL_REF=(); CUR=$LCUR
        if [ "$interactive" -eq 1 ]; then
            _ou_oplog_interactive "$compact" local "Local edit log for '$branch'"
        else
            _ou_oplog_print "$compact" 0 "Local edit log for '$branch'"
        fi
    else
        _ou_sync || return 1
        [ "${#TL_SHA[@]}" -gt 0 ] || { echo "${C_DIM}No operations recorded yet. (Run git undo to start.)${C_RESET}"; return 0; }
        if [ "$interactive" -eq 1 ]; then
            _ou_oplog_interactive "$compact" global "Global operation log"
        else
            _ou_oplog_print "$compact" 0 "Global operation log"
        fi
    fi
}

git-undo-log() {
    local compact interactive=0 mode=""
    compact=$(_ou_cfg_oplog_compact)        # default view from undoredo.oplog; -c/-f override
    local _ua; mapfile -t _ua < <(_ou_unbundle "$@"); set -- ${_ua[@]+"${_ua[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)        _ou_help_oplog; return 0 ;;
            --reset)          _ou_reset; return $? ;;
            -c|--compact)     compact=1 ;;
            -f|--full)        compact=0 ;;
            -g|--global)      mode=global ;;
            -l|--local)       mode=local ;;
            -i|--interactive) interactive=1 ;;
            *) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_oplog >&2; return 2 ;;
        esac
        shift
    done
    _ou_require_repo || return 1
    [ -z "$mode" ] && mode=$(_ou_cfg_default)   # neither flag: follow undoredo.default
    _ou_show "$mode" "$compact" "$interactive"
}

# Reset the oplog: drop the tracked state (global timeline + cursor, all per-branch
# logs, keep-refs) so the next command rebuilds it cleanly from git's reflog. This
# is a REBUILD, not a wipe - re-deriving from the reflog is exactly how the tool is
# meant to work, so recent history stitches back in; what's dropped is accumulated
# tracking older than the reflog, prime anchors, and any wedged state. Does NOT touch
# your commits or working tree. Exposed as `git oplog --reset`.
_ou_reset() {
    _ou_require_repo || return 1
    local sdir r redo=0 had=0
    sdir=$(_ou_state_dir) || return 1

    if _ou_load; then had=1; redo=$(( ${#TL_SHA[@]} - 1 - CUR )); fi
    for r in $(git for-each-ref --format='%(refname)' refs/git-undo-redo/keep/ 2>/dev/null); do
        git update-ref -d "$r"
    done
    rm -f "$sdir/timeline" "$sdir/cursor" 2>/dev/null
    rm -rf "$sdir/local" 2>/dev/null            # per-branch oplogs

    if [ "$had" -eq 0 ]; then
        echo "${C_DIM}Nothing to reset - no oplog exists yet.${C_RESET}"
        return 0
    fi
    echo "${C_OK}🔄 Reset the oplog.${C_RESET} It rebuilds from git's reflog on the next command; your commits and files are untouched."
    if [ "$redo" -gt 0 ]; then
        echo "${C_DIM}Note: any redo trail ahead of you, and tracking older than your reflog, isn't"
        echo "      re-derived and is no longer protected from gc (git's reflog keeps it until expiry).${C_RESET}"
    fi
}

# ---- CLI dispatcher: runs only when executed, not when sourced -------
# Multi-call binary: symlink (or copy) this file to git-undo, git-redo,
# git-oplog, git-opstatus on your PATH; each dispatches by its invoked name.
# The umbrella name (git-undo-redo) also takes the command as its first arg.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    _ou_load_config     # one git-config read for all undoredo.* keys
    _ou_colors          # set up ANSI colors once (no-op when piped / disabled)
    case "$(basename "$0")" in
        git-undo)     git-undo     "$@" ;;
        git-redo)     git-redo     "$@" ;;
        git-oplog)    git-undo-log "$@" ;;
        git-opstatus) git-undo-status "$@" ;;
        git-take)     git-take     "$@" ;;
        *)
            case "${1:-help}" in
                undo)           shift; git-undo        "$@" ;;
                redo)           shift; git-redo        "$@" ;;
                oplog)          shift; git-undo-log    "$@" ;;
                opstatus)       shift; git-undo-status "$@" ;;
                take)           shift; git-take        "$@" ;;
                reset|--reset)  _ou_reset ;;
                help|-h|--help) _ou_usage ;;
                *)              echo "${C_ERR}Unknown command: $1${C_RESET}" >&2; echo >&2; _ou_usage >&2; exit 2 ;;
            esac
            ;;
    esac
fi

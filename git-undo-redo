# ---- public commands ------------------------------------------------

# Expand bundled single-dash short flags so `-ls` parses as `-l -s`. Only a token
# that is a dash followed by two-or-more letters AND nothing but letters is split
# (so long `--flags`, a single `-e`, a bare number, and `-e3` are left untouched -
# the last stays "unknown", since a count is a separate arg: `git undo -e 3`).
# Each dispatcher runs its args through this before parsing, then re-sets its positionals:
#   _ou_unbundle "$@"; set -- ${OU_UA[@]+"${OU_UA[@]}"}
# Populates the OU_UA array IN-PLACE (no `mapfile < <(...)` process-substitution fork).
_ou_unbundle() {
    OU_UA=(); local a body i
    for a in "$@"; do
        case "$a" in
            -[A-Za-z][A-Za-z]*)
                body="${a#-}"
                case "$body" in
                    *[!A-Za-z]*) OU_UA+=("$a") ;;   # has a non-letter: leave as-is
                    *) for (( i=0; i<${#body}; i++ )); do OU_UA+=("-${body:i:1}"); done ;;
                esac ;;
            *) OU_UA+=("$a") ;;
        esac
    done
}

# Action by default; a view flag (--status/--log/--interactive) looks instead of moves.
# Edit scope by default; -g/--global is the advanced cross-axis view. (Branch navigation
# is its own command, `git back`.)
git-undo() {
    local mode="" view="" count=1 compact wipnav=0
    compact=$(_ou_cfg_log_compact)        # default log density; -c/-f override
    _ou_unbundle "$@"; set -- ${OU_UA[@]+"${OU_UA[@]}"}
    # Help is two-tier: -h shows the essentials; -a/--advanced (or -h -a) shows the full
    # scope/views set. Pre-scan so '-h -a' in any order works and short-circuits cleanly.
    local _a _help=0 _adv=0
    for _a in "$@"; do case "$_a" in -h|--help) _help=1 ;; -a|--advanced) _help=1; _adv=1 ;; esac; done
    [ "$_help" -eq 1 ] && { [ "$_adv" -eq 1 ] && _ou_help_undo_full || _ou_help_undo; return 0; }
    while [ $# -gt 0 ]; do
        case "$1" in
            --reset)          _ou_reset; return $? ;;
            -e|--edit)        mode=edit ;;
            -g|--global)      mode=global ;;
            -w|--worktree)    wipnav=1 ;;
            -s|--status)      case "$view" in ""|status)      view=status ;;      *) view=CONFLICT ;; esac ;;
            -l|--log)         case "$view" in ""|log)         view=log ;;         *) view=CONFLICT ;; esac ;;
            -i|--interactive) case "$view" in ""|interactive) view=interactive ;; *) view=CONFLICT ;; esac ;;
            -c|--compact)     compact=1 ;;
            -f|--full)        compact=0 ;;
            *)  case "$1" in
                    [Aa][Ll][Ll]) count=all ;;          # 'all' = undo as far back as the log goes
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_undo >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many to undo
                esac ;;
        esac
        shift
    done
    [ "$view" = CONFLICT ] && { echo "${C_ERR}Choose only one of --status, --log, --interactive.${C_RESET}" >&2; return 2; }
    _ou_require_repo  || return 1
    if [ "$wipnav" -eq 1 ]; then                        # -w/--worktree: step parked uncommitted-work versions
        case "$view" in
            log)         _ou_wip_show "$compact" 0; return $? ;;
            interactive) _ou_wip_show "$compact" 1; return $? ;;
            status)      _ou_wip_status; return $? ;;
            *)           _ou_wip_nav undo "$count"; return $? ;;
        esac
    fi
    [ -z "$mode" ] && mode=$(_ou_cfg_scope)

    case "$view" in                                     # a view flag looks instead of moving
        status)      _ou_status_show "$mode"; return $? ;;
        log)         _ou_show "$mode" "$compact" 0; return $? ;;
        interactive) _ou_show "$mode" "$compact" 1; return $? ;;
    esac

    [ "$count" != all ] && [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to undo (0 requested).${C_RESET}"; return 0; }
    case "$mode" in
        global)     _ou_undo_global "$count" ;;
        *)          _ou_undo_local "$count" ;;
    esac
}

git-redo() {
    local mode="" view="" count=1 compact wipnav=0
    compact=$(_ou_cfg_log_compact)        # default log density; -c/-f override
    _ou_unbundle "$@"; set -- ${OU_UA[@]+"${OU_UA[@]}"}
    local _a _help=0 _adv=0                # two-tier help (see git-undo)
    for _a in "$@"; do case "$_a" in -h|--help) _help=1 ;; -a|--advanced) _help=1; _adv=1 ;; esac; done
    [ "$_help" -eq 1 ] && { [ "$_adv" -eq 1 ] && _ou_help_redo_full || _ou_help_redo; return 0; }
    while [ $# -gt 0 ]; do
        case "$1" in
            --reset)          _ou_reset; return $? ;;
            -e|--edit)        mode=edit ;;
            -g|--global)      mode=global ;;
            -w|--worktree)    wipnav=1 ;;
            -s|--status)      case "$view" in ""|status)      view=status ;;      *) view=CONFLICT ;; esac ;;
            -l|--log)         case "$view" in ""|log)         view=log ;;         *) view=CONFLICT ;; esac ;;
            -i|--interactive) case "$view" in ""|interactive) view=interactive ;; *) view=CONFLICT ;; esac ;;
            -c|--compact)     compact=1 ;;
            -f|--full)        compact=0 ;;
            *)  case "$1" in
                    [Aa][Ll][Ll]) count=all ;;          # 'all' = redo forward to the most recent state
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_redo >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many to redo
                esac ;;
        esac
        shift
    done
    [ "$view" = CONFLICT ] && { echo "${C_ERR}Choose only one of --status, --log, --interactive.${C_RESET}" >&2; return 2; }
    _ou_require_repo  || return 1
    if [ "$wipnav" -eq 1 ]; then                        # -w/--worktree: parked-work versions (views identical to undo's)
        case "$view" in
            log)         _ou_wip_show "$compact" 0; return $? ;;
            interactive) _ou_wip_show "$compact" 1; return $? ;;
            status)      _ou_wip_status; return $? ;;
            *)           _ou_wip_nav redo "$count"; return $? ;;
        esac
    fi
    [ -z "$mode" ] && mode=$(_ou_cfg_scope)

    case "$view" in                                     # the views are read-only and identical to undo's
        status)      _ou_status_show "$mode"; return $? ;;
        log)         _ou_show "$mode" "$compact" 0; return $? ;;
        interactive) _ou_show "$mode" "$compact" 1; return $? ;;
    esac

    [ "$count" != all ] && [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to redo (0 requested).${C_RESET}"; return 0; }
    case "$mode" in
        global)     _ou_redo_global "$count" ;;
        *)          _ou_redo_local "$count" ;;
    esac
}

# `git back [N]` / `git forward [N]` - navigation undo/redo: step back / forward through
# your branch switches & checkouts (the navigation log). The same atomic-checkout engine
# the old `git undo -n` used, but their own commands so undo/redo never yank your branch.
# They take the read-only views (-s/-l/-i) and density flags (-c/-f), nothing else - no
# scopes, no advanced help.
git-back()    { _ou_navcmd back    "$@"; }
git-forward() { _ou_navcmd forward "$@"; }
_ou_navcmd() {
    local dir="$1"; shift
    local view="" count=1 compact _a
    compact=$(_ou_cfg_log_compact)
    _ou_unbundle "$@"; set -- ${OU_UA[@]+"${OU_UA[@]}"}
    for _a in "$@"; do case "$_a" in -h|--help) [ "$dir" = back ] && _ou_help_back || _ou_help_forward; return 0 ;; esac; done
    while [ $# -gt 0 ]; do
        case "$1" in
            -s|--status)      case "$view" in ""|status)      view=status ;;      *) view=CONFLICT ;; esac ;;
            -l|--log)         case "$view" in ""|log)         view=log ;;         *) view=CONFLICT ;; esac ;;
            -i|--interactive) case "$view" in ""|interactive) view=interactive ;; *) view=CONFLICT ;; esac ;;
            -c|--compact)     compact=1 ;;
            -f|--full)        compact=0 ;;
            *)  case "$1" in
                    [Aa][Ll][Ll]) count=all ;;          # 'all' = go as far in this direction as the log allows
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2
                                 { [ "$dir" = back ] && _ou_help_back || _ou_help_forward; } >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = how many steps
                esac ;;
        esac
        shift
    done
    [ "$view" = CONFLICT ] && { echo "${C_ERR}Choose only one of --status, --log, --interactive.${C_RESET}" >&2; return 2; }
    _ou_require_repo || return 1
    case "$view" in                                     # a view flag looks instead of moving
        status)      _ou_status_show navigation; return $? ;;
        log)         _ou_show navigation "$compact" 0; return $? ;;
        interactive) _ou_show navigation "$compact" 1; return $? ;;
    esac
    [ "$count" != all ] && [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to move (0 requested).${C_RESET}"; return 0; }
    if [ "$dir" = back ]; then _ou_undo_nav "$count"; else _ou_redo_nav "$count"; fi
}

git-take() {
    local count="" mode=""
    _ou_unbundle "$@"; set -- ${OU_UA[@]+"${OU_UA[@]}"}
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)        _ou_help_take; return 0 ;;
            -s|--staged)      mode=staged ;;
            -u|--unstaged)    mode=unstaged ;;
            *)  case "$1" in
                    [Aa][Ll][Ll]) count=all ;;          # 'all' = the branch's latest edit (old bare-take)
                    ''|*[!0-9]*) echo "${C_ERR}Unknown option: $1${C_RESET}" >&2; echo >&2; _ou_help_take >&2; return 2 ;;
                    *)           count=$((10#$1)) ;;     # bare number = the Nth entry above current
                esac ;;
        esac
        shift
    done
    _ou_require_repo || return 1
    [ -n "$count" ] && [ "$count" != all ] && [ "$count" -lt 1 ] && { echo "${C_DIM}Nothing to take (0 requested).${C_RESET}"; return 0; }
    [ -z "$mode" ] && mode=$(_ou_cfg_take)   # no flag: follow undoredo.take (default unstaged)
    _ou_take "$count" "$mode"
}

# ---- dirty-worktree parking (the engine behind `git goto`) ----------
# Park the tracked dirty worktree as a hidden, per-base-commit snapshot that PRESERVES the
# staged/unstaged split, then restore it on return. We reuse `git stash create` / `git
# stash apply --index`, so the user's `git stash` stack is never touched. Snapshots are
# ordered in a per-base timeline (.git/git-undo-redo/wip/<base>/timeline) and gc-protected
# under refs/git-undo-redo/wipkeep/<sha> - its own namespace from the oplog's keep refs
# (though `git undo --reset` clears both: it is a full clear of the tool's tracked state).
# Untracked files are intentionally left in the worktree (they travel with a switch).

# wip state lives at "$_OU_SDIR/wip/<id>" (id = '<commit>@<branch>'); callers build that path
# inline (no subshell) since _OU_SDIR is already resolved on every command's hot path.

# A wip bucket is keyed by BRANCH + COMMIT, not the commit alone: dirty work parked while on
# (branch A @ commit C) must never be restored onto (branch B @ the SAME commit C) - e.g.
# `git goto -c newbranch` lands a brand-new branch on the current commit, and the work you
# left belongs to the branch you came from, not the new one. The id is '<commit>@<branch>'
# (branch '%2F'-encoded for path safety; ':detached' when HEAD has no branch). Prune reads
# the commit back as the part before '@'.
# Build a wip id into the variable named $1 (via `printf -v`, so no subshell fork) from a
# raw branch $2 ("" = detached) and commit sha $3.
_ou_wip_setid() {
    local _ouv_b="${2:-:detached}"
    [ -n "$_ouv_b" ] || _ouv_b=":detached"
    _ouv_b="${_ouv_b//%/%25}"; _ouv_b="${_ouv_b////%2F}"
    printf -v "$1" '%s@%s' "$3" "$_ouv_b"
}
# Set $1 to the wip id for the CURRENT HEAD (branch + commit), read FRESH in ONE git call -
# never the cached _OU_BRANCH, since `git goto` flips the branch mid-command. `git rev-parse
# HEAD --abbrev-ref HEAD` yields '<sha>\n<branch-or-HEAD>'. Returns 1 when there's no commit.
_ou_wip_setcurid() {
    local _ouv_out _ouv_c _ouv_b
    _ouv_out=$(git rev-parse HEAD --abbrev-ref HEAD 2>/dev/null) || return 1
    _ouv_c="${_ouv_out%%$'\n'*}"; [ -n "$_ouv_c" ] || return 1
    _ouv_b="${_ouv_out##*$'\n'}"; [ "$_ouv_b" = HEAD ] && _ouv_b=""   # 'HEAD' = detached
    _ou_wip_setid "$1" "$_ouv_b" "$_ouv_c"
}

# Apply parked snapshot $1 onto a clean worktree, preserving the staged/unstaged split via
# `git stash apply --index`. If that split can't be reproduced (an index conflict), fall
# back to a flat apply - the content is still restored - and stage it per `undoredo.take`
# (default unstaged), so the one case where tracking is lost lands the way `git take` would.
_ou_wip_apply() {
    local s="$1"
    [ "$s" = clean ] && return 0   # a 'clean' version: the caller has already reset to HEAD; nothing to apply
    [ -n "$s" ] || return 1
    # No upfront `git cat-file -e` verify: callers always have a CLEAN tree here, so a bad/
    # missing ref just fails the apply (and the harmless reset below) and we return 1 - same
    # outcome, one fewer fork on every restore.
    git stash apply --index "$s" >/dev/null 2>&1 && return 0
    git reset --hard --quiet HEAD 2>/dev/null            # clear any partial apply, then land flat
    git stash apply "$s" >/dev/null 2>&1 || return 1
    [ "$(_ou_cfg_take)" = staged ] && git add -A >/dev/null 2>&1
    return 0
}

# Record a worktree version against base commit $1: a snapshot (deduped against the last),
# gc-protected and VERIFIED. $2 is the value to record: a pre-made `git stash create` sha
# (goto snapshots up front and records only once the switch succeeds), or the literal
# `clean` to record a clean-tree version (you left this commit with nothing uncommitted, so
# returning here should land clean, not resurrect an older dirty version). With no $2 it
# captures the current tree. Returns 0 when safe to clobber the worktree; 1 if the save
# couldn't be guaranteed (caller must then refuse rather than risk losing work).
# Do version refs $1 and $2 denote the same working tree? Handles the 'clean' sentinel
# (clean matches only clean). One git call for the dirty/dirty case.
_ou_wip_same() {
    local a="$1" b="$2" t
    if [ "$a" = clean ] || [ "$b" = clean ]; then [ "$a" = "$b" ]; return; fi
    t=$(git rev-parse "$a^{tree}" "$b^{tree}" 2>/dev/null)   # both trees, one call (no --verify: rejects 2 args)
    [ "${t%%$'\n'*}" = "${t##*$'\n'}" ]
}

# Park the live tracked tree ($2, or a fresh stash; 'clean' for an intentionally empty tree)
# as a version of base commit $1, honoring this bucket's cursor - so leaving and returning
# behaves like commit undo/redo:
#   * tree unchanged from the cursor's version  -> record nothing (you STAY at that point)
#   * changed while ABOVE older versions (cursor below the tail = you acted after stepping
#     back) -> drop a resume-point prime of the cursor version, THEN append the change as the
#     new tail (so the versions above aren't orphaned, exactly like the commit log's B' D)
#   * changed at the tail                        -> just append the change as the new tail
# The cursor always ends on the version the worktree now holds, so _ou_wip_restore brings
# you back to precisely where you left.
_ou_wip_park() {
    local base="$1" s="${2:-}" d tl arr n wcur cur last
    [ -n "$base" ] || return 0
    [ -n "$s" ] || s=$(git stash create "git-undo-redo: worktree @ ${base:0:12}" 2>/dev/null) || return 1
    [ -n "$s" ] || return 0                       # nothing tracked-dirty to park
    d="${_OU_SDIR:-$(_ou_state_dir)}/wip/$base"; mkdir -p "$d" || return 1   # inline dir (no subshell)
    tl="$d/timeline"
    if [ ! -s "$tl" ]; then
        [ "$s" = clean ] && return 0              # never START a timeline from a clean tree
        git update-ref "refs/git-undo-redo/wipkeep/$s" "$s" 2>/dev/null      # gc-protect (clean has no object)
        printf '%s\n' "$s" >> "$tl" || return 1
        git cat-file -e "$s" 2>/dev/null || return 1   # verify the snapshot object is really stored
        printf '0\n' > "$d/cursor"
        _ou_wip_prune "$base"                      # tidy stale buckets (skip this one - it's alive)
        return 0
    fi
    mapfile -t arr < "$tl"; n=${#arr[@]}          # last line + count without forks
    wcur=$(( n - 1 )); [ -r "$d/cursor" ] && read -r wcur < "$d/cursor"
    { [ "$wcur" -ge 0 ] && [ "$wcur" -lt "$n" ]; } || wcur=$(( n - 1 ))
    cur="${arr[$wcur]%%$'\t'*}"                    # the version the cursor sits on (strip any kind)
    _ou_wip_same "$s" "$cur" && return 0           # unchanged: stay at this point (cursor persists)
    if [ "$wcur" -lt $(( n - 1 )) ]; then          # changed after stepping back: keep a resume point
        last="${arr[$(( n - 1 ))]}"                # ...unless an identical prime is already the tail
        if ! { [ "${last#*$'\t'}" = prime ] && [ "${last%%$'\t'*}" = "$cur" ]; }; then
            [ "$cur" = clean ] || git update-ref "refs/git-undo-redo/wipkeep/$cur" "$cur" 2>/dev/null
            printf '%s\tprime\n' "$cur" >> "$tl" || return 1
            n=$(( n + 1 ))
        fi
    fi
    [ "$s" = clean ] || git update-ref "refs/git-undo-redo/wipkeep/$s" "$s" 2>/dev/null
    printf '%s\n' "$s" >> "$tl" || return 1
    [ "$s" = clean ] || git cat-file -e "$s" 2>/dev/null || return 1
    printf '%s\n' "$n" > "$d/cursor"               # cursor -> the just-appended tail
    _ou_wip_prune "$base"
}

# Restore the latest parked worktree for base commit $1 onto the (assumed clean) worktree,
# preserving the staged/unstaged split. Best-effort: an index conflict degrades to an
# all-unstaged apply (content still safe). Prints a line only when it actually restores.
_ou_wip_restore() {
    local base="$1" d tl s _ss _kk n wcur undo redo
    local WT_SHA WT_KIND                            # so the version-label helpers can see them
    [ -n "$base" ] || return 0
    d="${_OU_SDIR:-$(_ou_state_dir)}/wip/$base"; tl="$d/timeline"
    [ -s "$tl" ] || return 0                        # no parked work for this branch+commit: 0 forks, done
    WT_SHA=(); WT_KIND=()
    while IFS=$'\t' read -r _ss _kk; do [ -n "$_ss" ] && { WT_SHA+=("$_ss"); WT_KIND+=("${_kk:-version}"); }; done < "$tl"
    n=${#WT_SHA[@]}; [ "$n" -gt 0 ] || return 0     # line count without forks
    # Return to where the cursor left off (commit-undo parity): if you stepped back with
    # 'git undo --worktree' and left without changing anything, the cursor still points there.
    wcur=$(( n - 1 )); [ -r "$d/cursor" ] && read -r wcur < "$d/cursor"
    { [ "$wcur" -ge 0 ] && [ "$wcur" -lt "$n" ]; } || wcur=$(( n - 1 ))
    s="${WT_SHA[$wcur]}"; [ -n "$s" ] || return 0   # cursor's version
    undo="$wcur"; redo=$(( n - 1 - wcur ))          # steps available on each side of the cursor
    if [ "$s" = clean ]; then
        # You left this branch+commit with a CLEAN tree: arriving clean is what you want, so
        # don't restore anything. But if other parked versions sit around it, point them out
        # with the worktree meter - they're a 'git undo --worktree' away.
        printf '%s\n' "$wcur" > "$d/cursor" 2>/dev/null
        [ "$n" -gt 1 ] && echo "${C_OK}↜${C_RESET} ${C_DIM}'git undo --worktree' for an earlier parked version  (undo: $undo · redo: $redo)${C_RESET}"
        return 0
    fi
    if _ou_wip_apply "$s"; then                     # _ou_wip_apply verifies the object itself
        printf '%s\n' "$wcur" > "$d/cursor" 2>/dev/null   # cursor -> the version we just restored
        local lbl; lbl="$(_ou_wip_vlabel "$wcur") ${C_OK}${s:0:7}${C_RESET}"   # "v7 7207c4f" / "↻ v3 5f36788" (sha green)
        if [ "$n" -gt 1 ]; then                     # meter + hint only when there's somewhere to step
            echo "${C_OK}↜ Restored your parked changes from${C_RESET} $lbl ${C_DIM}(undo: $undo · redo: $redo)${C_RESET}"
            echo "  ${C_DIM}Edit and commit, or 'git undo --worktree' for an earlier version.${C_RESET}"
        else
            echo "${C_OK}↜ Restored your parked changes from${C_RESET} $lbl"
        fi
    fi
}

# Around a move (undo/redo, picker jump): park the current tracked dirty worktree so the
# move can't clobber it - refusing ONLY if it can't be guaranteed saved - then restore
# whatever is parked against wherever HEAD ends up. This is what lets undo/redo run on a
# dirty tree (no "commit or stash first" refusal) without ever losing work. `_ou_wip_after`
# restores the DESTINATION's parked work on success, or the origin's if the move failed
# (HEAD didn't move), so nothing is ever stranded.
_ou_wip_before() {
    # `git stash create` IS the dirty check (empty = clean tracked tree, or untracked-only).
    # HEAD hasn't moved yet, so the cached _OU_HEAD/_OU_BRANCH (from _ou_require_repo) give
    # the leaving id with zero extra forks.
    local snap base tl; snap=$(git stash create "git-undo-redo: worktree" 2>/dev/null)
    _ou_wip_setid base "$_OU_BRANCH" "$_OU_HEAD"
    tl="${_OU_SDIR:-$(_ou_state_dir)}/wip/$base/timeline"
    if [ -z "$snap" ]; then
        # Clean tree: only record a 'clean' version if this commit ALREADY has parked work
        # (so returning lands clean, not on a stale dirty version). Don't START a timeline
        # from a clean tree - there'd be nothing to come back to.
        [ -s "$tl" ] || return 0
        snap=clean
    else
        # Real dirty work is about to leave the tree - count it, so the mover can SAY so
        # (observable safety: the instant your changes vanish, the output tells you where).
        # Count from `git status` (tracked changes, staged AND unstaged) - that's exactly what
        # the stash parks. Diffing HEAD against the stash's *tree* would miss index-only changes
        # (staged, then the worktree reverted), so they'd park silently. `git status` sees both.
        _OU_PARKED=$(git status --porcelain --untracked-files=no 2>/dev/null | grep -c .)
    fi
    if ! _ou_wip_park "$base" "$snap"; then
        echo "${C_ERR}❌ Couldn't safely save your uncommitted changes - not moving.${C_RESET}" >&2
        echo "   ${C_DIM}Commit or stash them and try again.${C_RESET}" >&2
        return 1
    fi
    git reset --hard --quiet HEAD 2>/dev/null
}
_ou_wip_after() {
    # Fast path: if nothing has ever been parked (no wip dir), there's nothing to restore -
    # skip the HEAD lookup entirely. This is the common case (most users never goto/park).
    [ -d "${_OU_SDIR:-$(_ou_state_dir)}/wip" ] || return 0
    local h; _ou_wip_setcurid h && _ou_wip_restore "$h"   # restore whatever's parked for where we landed
}

# After a dirty undo/redo/back/forward set your live work aside (via _ou_wip_before), say so:
# where it went and the single command that brings it back. Answers the "where did my changes
# go?" panic in one line, in the moment. $1 = the command that returns you to it. No-op when
# nothing dirty was parked.
_ou_parked_note() {
    [ "${_OU_PARKED:-0}" -gt 0 ] || return 0
    echo "${C_OK}↜ Set aside your $(_ou_qty "$_OU_PARKED" "uncommitted file")${C_RESET} ${C_DIM}- '$1' brings them back.${C_RESET}"
}

# Worktree-version navigation (the `-w`/`--worktree` mode): step through a commit's parked
# working-tree versions. State per base: the snapshot timeline + a cursor.
_ou_wip_load() {   # base $1 -> WT_SHA[]/WT_KIND[] (oldest..newest) + WCUR; returns 1 if no parked work
    local d tl _s _k; d="${_OU_SDIR:-$(_ou_state_dir)}/wip/$1"; tl="$d/timeline"; [ -s "$tl" ] || return 1
    WT_SHA=(); WT_KIND=()
    while IFS=$'\t' read -r _s _k; do [ -n "$_s" ] && { WT_SHA+=("$_s"); WT_KIND+=("${_k:-version}"); }; done < "$tl"
    [ "${#WT_SHA[@]}" -gt 0 ] || return 1
    WCUR=$(( ${#WT_SHA[@]} - 1 ))
    [ -r "$d/cursor" ] && read -r WCUR < "$d/cursor"
    { [ "$WCUR" -ge 0 ] && [ "$WCUR" -lt "${#WT_SHA[@]}" ]; } || WCUR=$(( ${#WT_SHA[@]} - 1 ))
}
_ou_wip_save_cursor() { local d; d="${_OU_SDIR:-$(_ou_state_dir)}/wip/$1"; [ -d "$d" ] && printf '%s\n' "$WCUR" > "$d/cursor"; }

# Save the current live (unsaved) tracked state as a new tail version on timeline $1 - used
# when we're about to load a parked version and the worktree holds work that isn't itself a
# parked version yet (so nothing is lost). No-op (returns 1) if the tree is clean or already
# identical to the latest version. Appends to the in-scope WT_SHA[]/WT_KIND[] the caller
# loaded. Full symmetry with the leave path (and commit undo/redo): if the cursor sits BELOW
# the tail (you're saving an edit made after stepping back), drop a resume-point prime of the
# cursor version first, so the versions above aren't orphaned.
_ou_wip_stamp_live() {
    local tl="$1" cs tail t cur last
    cs=$(git stash create 2>/dev/null); [ -n "$cs" ] || return 1
    tail="${WT_SHA[$(( ${#WT_SHA[@]} - 1 ))]}"
    t=$(git rev-parse "$cs^{tree}" "$tail^{tree}" 2>/dev/null)   # both trees in one call (no --verify: it rejects 2 args)
    [ "${t%%$'\n'*}" = "${t##*$'\n'}" ] && return 1
    if [ "$WCUR" -lt $(( ${#WT_SHA[@]} - 1 )) ]; then            # acted after stepping back: keep a resume point
        cur="${WT_SHA[$WCUR]}"; last="${WT_KIND[$(( ${#WT_SHA[@]} - 1 ))]:-version}"
        if ! { [ "$last" = prime ] && [ "$tail" = "$cur" ]; }; then   # ...unless an identical prime is already the tail
            [ "$cur" = clean ] || git update-ref "refs/git-undo-redo/wipkeep/$cur" "$cur" 2>/dev/null
            printf '%s\tprime\n' "$cur" >> "$tl"; WT_SHA+=("$cur"); WT_KIND+=("prime")
        fi
    fi
    git update-ref "refs/git-undo-redo/wipkeep/$cs" "$cs" 2>/dev/null
    printf '%s\n' "$cs" >> "$tl"; WT_SHA+=("$cs"); WT_KIND+=("version")
}

# Is the cursor's version actually present in the worktree right now? 0 = yes (we got here
# via goto / a prior --worktree, so stepping is relative to it); 1 = no (e.g. a plain `git switch`
# bypassed our restore, or there are live edits) - the parked work isn't loaded. This is a
# READ-ONLY check: `git diff --quiet` compares the live worktree to the cursor version's tree
# without WRITING objects (the old `git stash create` materialized a throwaway stash just to
# compare - wasteful for status/log listings).
_ou_wip_cursor_loaded() {
    if [ "${WT_SHA[$WCUR]}" = clean ]; then
        git diff --quiet HEAD 2>/dev/null                    # 'clean' version loaded iff the tree is clean vs HEAD
    else
        git diff --quiet "${WT_SHA[$WCUR]}" -- 2>/dev/null   # dirty version loaded iff the worktree equals its tree
    fi
}

# Is base commit $1 still recoverable WITHOUT the wip itself - reachable from a branch/tag,
# our oplog keep-refs, or HEAD's reflog? (The snapshot pins its own base, so we check only
# the non-wip sources.) 0 = keep; 1 = the base is gone from git AND our oplogs, so its
# parked work has no restorable context and may be pruned.
_ou_wip_base_alive() {   # $1 = commit, $2 = pre-dumped reflog (HEAD %H lines) to match against
    local C="$1"
    [ -n "$(git for-each-ref --contains="$C" --count=1 refs/heads refs/tags refs/git-undo-redo/keep 2>/dev/null)" ] && return 0
    case "$2" in *"$C"*) return 0 ;; esac   # full sha can only match a whole reflog line (no grep fork)
    return 1
}

# Drop wip logs whose base commit is unrecoverable from BOTH git (branches/tags/reflog) and
# our oplogs - so parked work tied to anything restorable is always kept. $1 = the bucket we
# just parked to (alive by definition); skipping it means the common single-bucket park does
# ZERO extra git calls. The reflog is dumped at most once, only if some OTHER bucket needs it.
_ou_wip_prune() {
    local skip="$1" wroot d id C s reflog="" got=0
    wroot="${_OU_SDIR:-$(_ou_state_dir)}/wip"; [ -d "$wroot" ] || return 0
    for d in "$wroot"/*; do
        [ -d "$d" ] || continue
        id="${d##*/}"; [ "$id" = "$skip" ] && continue   # the just-parked bucket is alive
        C="${id%%@*}"                                     # bucket id is '<commit>@<branch>'
        [ "$got" -eq 0 ] && { reflog=$(git reflog --format='%H' 2>/dev/null); got=1; }
        _ou_wip_base_alive "$C" "$reflog" && continue
        if [ -r "$d/timeline" ]; then
            while IFS=$'\t' read -r s _; do [ -n "$s" ] && git update-ref -d "refs/git-undo-redo/wipkeep/$s" 2>/dev/null; done < "$d/timeline"
        fi
        rm -rf "$d" 2>/dev/null
    done
}

# `git undo --worktree [N]` / `git redo --worktree [N]`: step through THIS commit's parked working-
# tree versions (from `git goto` or a dirty undo/redo). Saves any unsaved edits as a new
# version first (nothing lost), then restores the older (undo) / newer (redo) snapshot with
# its staged/unstaged split. $1 = undo|redo, $2 = count.
_ou_wip_nav() {
    local dir="$1" count="${2:-1}" base tl n target verb
    local WT_SHA WT_KIND WCUR
    _ou_wip_setcurid base || { echo "${C_DIM}No commit yet - nothing parked.${C_RESET}"; return 1; }
    _ou_wip_load "$base" || { echo "${C_DIM}No parked working changes for this commit.${C_RESET}"; return 1; }
    tl="${_OU_SDIR:-$(_ou_state_dir)}/wip/$base/timeline"

    # Worktree doesn't hold the cursor's version (e.g. you got here with a plain `git switch`,
    # which never restored the parked work; or you've made live edits). Don't step past what
    # you can't see: save any live edits as a new tail first (nothing lost), then LOAD the
    # latest parked version - the same parking-what-you-leave behavior `git goto` has.
    if ! _ou_wip_cursor_loaded; then
        local pre=${#WT_SHA[@]} saved=0
        _ou_wip_stamp_live "$tl" && saved=1
        n=${#WT_SHA[@]}
        if [ "$dir" = redo ]; then
            target=$(( pre - 1 ))                       # nothing newer than live work: load the latest
        else
            [ "$count" = all ] && count=$pre            # 'all' -> the oldest parked version
            target=$(( pre - 1 - (count - 1) ))         # undo: count 1 -> the latest, deeper -> further back
            [ "$target" -lt 0 ] && { echo "${C_ERR}🛑 Only $pre parked version(s); you asked for $count. Nothing changed.${C_RESET}"; return 1; }
        fi
        git reset --hard --quiet HEAD 2>/dev/null
        _ou_wip_apply "${WT_SHA[$target]}"
        WCUR="$target"; _ou_wip_save_cursor "$base"
        if [ "$saved" -eq 1 ]; then
            echo "${C_OK}↜ Saved your current changes and loaded parked version $(_ou_wip_vnum "$target") of $(_ou_wip_vtot)${C_RESET} ${C_DIM}(${WT_SHA[$target]:0:7} · undo: $WCUR · redo: $(( n - 1 - WCUR )))${C_RESET}"
        else
            echo "${C_OK}↜ Loaded parked version $(_ou_wip_vnum "$target") of $(_ou_wip_vtot)${C_RESET} ${C_DIM}(${WT_SHA[$target]:0:7} · undo: $WCUR · redo: $(( n - 1 - WCUR )))${C_RESET}"
        fi
        return 0
    fi

    # The cursor's version IS loaded (goto / a prior --worktree put it there): step relative to it.
    n="${#WT_SHA[@]}"; local tot; tot=$(_ou_wip_vtot)
    if [ "$dir" = undo ]; then
        if [ "$WCUR" -le 0 ]; then echo "${C_ERR}🛑 Already at the oldest parked version (1 of $tot).${C_RESET}"; return 1; fi
        [ "$count" = all ] && count=$WCUR               # 'all' -> the oldest parked version
        [ "$count" -gt "$WCUR" ] && { echo "${C_ERR}🛑 Only $WCUR earlier step(s) back; you asked for $count. Nothing changed.${C_RESET}"; return 1; }
        target=$(( WCUR - count )); verb="↶ Worktree undo"
    else
        local fwd=$(( n - 1 - WCUR ))
        [ "$count" = all ] && count=$fwd                # 'all' -> the newest parked version
        if [ "$fwd" -le 0 ]; then echo "${C_ERR}🛑 Already at the newest parked version ($tot of $tot).${C_RESET}"; return 1; fi
        [ "$count" -gt "$fwd" ] && { echo "${C_ERR}🛑 Only $fwd newer step(s); you asked for $count. Nothing changed.${C_RESET}"; return 1; }
        target=$(( WCUR + count )); verb="↷ Worktree redo"
    fi
    git reset --hard --quiet HEAD 2>/dev/null
    _ou_wip_apply "${WT_SHA[$target]}"
    WCUR="$target"; _ou_wip_save_cursor "$base"
    local lbl
    if [ "${WT_KIND[$target]:-version}" = prime ]; then lbl="a resume point"; else lbl="parked version $(_ou_wip_vnum "$target") of $tot"; fi
    echo "${C_OK}${verb} →${C_RESET} $lbl ${C_DIM}(${WT_SHA[$target]:0:7} · undo: $WCUR · redo: $(( n - 1 - WCUR )))${C_RESET}"
}

# `git undo --worktree --log` / `--status` / `--interactive`: show this commit's parked working-
# tree versions (newest first), or open a picker to load one. Read-only except the picker.
# Version number for index $1, counting real versions only (resume-point primes don't
# consume a number). Echoes the bare integer; callers prepend "v".
_ou_wip_vnum() { local i="$1" j vn=0; for (( j=0; j<=i; j++ )); do [ "${WT_KIND[$j]:-version}" != prime ] && vn=$(( vn + 1 )); done; printf '%d' "$vn"; }
# Total real versions (primes excluded) in the loaded WT_SHA[].
_ou_wip_vtot() { local j tot=0; for (( j=0; j<${#WT_SHA[@]}; j++ )); do [ "${WT_KIND[$j]:-version}" != prime ] && tot=$(( tot + 1 )); done; printf '%d' "$tot"; }
# A prime shares its sha with the real version it resumed from; echo that version's number
# (the nearest non-prime below it with the same sha), so a row can read "↻ v3".
_ou_wip_prime_src() { local i="$1" s="${WT_SHA[$1]}" j; for (( j=i-1; j>=0; j-- )); do [ "${WT_KIND[$j]:-version}" != prime ] && [ "${WT_SHA[$j]}" = "$s" ] && { _ou_wip_vnum "$j"; return; }; done; printf '?'; }
# Colored label for the version at index $1: "v<n>" for a real version, "↻ v<src>" for a
# resume point (matching the log's coloring) - used in the restore message.
_ou_wip_vlabel() {
    if [ "${WT_KIND[$1]:-version}" = prime ]; then printf '%s↻ v%s%s' "$C_RESUME" "$(_ou_wip_prime_src "$1")" "$C_RESET"
    else printf '%sv%s%s' "$C_UNDO" "$(_ou_wip_vnum "$1")" "$C_RESET"; fi
}
# Will row $1 be hidden in compact mode? (a resume point that isn't the cursor's). $2=cursor idx.
_ou_wip_hidden() { [ "$3" -eq 1 ] && [ "${WT_KIND[$1]:-version}" = prime ] && [ "$1" -ne "$2" ]; }   # $1=idx $2=at $3=compact
# Legend suffix ", ↻ = resume point" - only when a prime row will actually be shown. $1=compact, $2=cursor idx.
_ou_wip_legend() {
    local compact="$1" at="$2" i
    for (( i=0; i<${#WT_SHA[@]}; i++ )); do _ou_wip_hidden "$i" "$at" "$compact" && continue
        [ "${WT_KIND[$i]:-version}" = prime ] && { printf ', %s↻%s = resume point' "$C_RESUME" "$C_MUTE"; return; }; done
}

# Fill WT_STAT[sha] with each parked version's one-line diffstat in a SINGLE git call, so
# listing the log is one fork instead of one `git stash show` per row (the old "receipt
# printing"). `git diff-tree --stdin -m` prints each commit's diff against EACH parent; for a
# `git stash create` commit the FIRST (parent 1 = the base it was taken on) is exactly what
# `git stash show` reports, so we keep the first shortstat per sha. The caller must have
# declared `local -A WT_STAT`. 'clean' versions carry no object and need no stat.
_ou_wip_loadstats() {
    local s line cur t; local -A _u; local -a uniq=()
    for s in "${WT_SHA[@]}"; do
        [ "$s" = clean ] && continue
        [ -n "${_u[$s]:-}" ] && continue
        _u[$s]=1; uniq+=("$s")
    done
    [ "${#uniq[@]}" -gt 0 ] || return 0
    while IFS= read -r line; do
        case "$line" in
            " "*) [ -n "${cur:-}" ] && [ -z "${WT_STAT[$cur]:-}" ] && { t="${line#"${line%%[![:space:]]*}"}"; WT_STAT[$cur]="$t"; } ;;
            [0-9a-f]*) cur="$line" ;;
        esac
    done < <(printf '%s\n' "${uniq[@]}" | git diff-tree --stdin --shortstat -m 2>/dev/null)
}

_ou_wip_row() {   # $1=idx into WT_SHA, $2=cursor idx to mark @ (-1 = none), $3=numbered, $4=sel number
    local i="$1" at="$2" numbered="$3" sn="$4" s k mark stat short
    s="${WT_SHA[$i]}"; k="${WT_KIND[$i]:-version}"
    [ "$i" -eq "$at" ] && mark=" ${C_AT}@${C_RESET}" || mark="  "
    if [ "$s" = clean ]; then
        short="clean  "; stat="clean working tree"
    else
        short="${s:0:7}"; stat="${WT_STAT[$s]:-no tracked changes}"   # precomputed by _ou_wip_loadstats (one fork)
    fi
    if [ "$k" = prime ]; then                       # resume point (↻, per the legend): same tree as the version it marks
        local src ref; src="v$(_ou_wip_prime_src "$i")"; [ "$s" = clean ] && ref="clean" || ref="${s:0:7}"
        if [ "$numbered" -eq 1 ]; then
            printf '%s %2d) %s↻ %s%s %s%s%s  %s\n' "$mark" "$sn" "$C_RESUME" "$src" "$C_RESET" "$C_DIM" "$ref" "$C_RESET" "$stat"
        else
            printf '%s  %s↻ %s%s %s%s%s  %s\n' "$(_ou_rel_mark "$i" "$at")" "$C_RESUME" "$src" "$C_RESET" "$C_DIM" "$ref" "$C_RESET" "$stat"
        fi
        return
    fi
    if [ "$numbered" -eq 1 ]; then
        printf '%s %2d) %sv%s%s %s%s%s  %s\n' "$mark" "$sn" "$C_UNDO" "$(_ou_wip_vnum "$i")" "$C_RESET" "$C_DIM" "$short" "$C_RESET" "$stat"
    else
        printf '%s  %sv%s%s %s%s%s  %s\n' "$(_ou_rel_mark "$i" "$at")" "$C_UNDO" "$(_ou_wip_vnum "$i")" "$C_RESET" "$C_DIM" "$short" "$C_RESET" "$stat"
    fi
}

_ou_wip_status() {
    local base n loadedcur=1
    local WT_SHA WT_KIND WCUR
    _ou_wip_setcurid base || { echo "${C_DIM}No commit yet - nothing parked.${C_RESET}"; return 0; }
    _ou_wip_load "$base" || { echo "${C_DIM}No parked working versions for this commit (${base:0:7}).${C_RESET}"; return 0; }
    n=${#WT_SHA[@]}; _ou_wip_cursor_loaded || loadedcur=0
    local tot; tot=$(_ou_wip_vtot)                  # real versions (resume points excluded)
    if [ "$loadedcur" -eq 1 ]; then
        echo "Parked working versions for ${C_DIM}${base:0:7}${C_RESET}: ${C_AT}$(_ou_wip_vnum "$WCUR") of $tot${C_RESET} loaded ${C_DIM}($WCUR back, $(( n - 1 - WCUR )) forward).${C_RESET}"
    else
        echo "Parked working versions for ${C_DIM}${base:0:7}${C_RESET}: ${C_AT}$tot${C_RESET} saved, none loaded ${C_DIM}('git undo --worktree' brings the latest into your worktree).${C_RESET}"
    fi
}

_ou_wip_show() {   # $1=compact (1=hide resume points except the cursor's), $2=interactive (0/1)
    local compact="$1" interactive="$2" base i n at loadedcur=1
    local WT_SHA WT_KIND WCUR; local -A WT_STAT
    _ou_wip_setcurid base || { echo "${C_DIM}No commit yet - nothing parked.${C_RESET}"; return 0; }
    _ou_wip_load "$base" || { echo "${C_DIM}No parked working changes for this commit.${C_RESET}"; return 0; }
    _ou_wip_loadstats                               # all diffstats in one git call (shared by log + picker)
    n=${#WT_SHA[@]}; _ou_wip_cursor_loaded || loadedcur=0
    [ "$loadedcur" -eq 1 ] && at="$WCUR" || at=-1
    [ "$interactive" -eq 1 ] && { _ou_wip_picker "$base" "$at" "$compact"; return $?; }
    echo "Parked working versions for ${C_DIM}${base:0:7}${C_RESET} ${C_MUTE}(newest first; ${C_AT}@${C_MUTE} = current worktree$(_ou_wip_legend "$compact" "$at"))${C_RESET}:"
    for (( i=n-1; i>=0; i-- )); do _ou_wip_hidden "$i" "$at" "$compact" && continue; _ou_wip_row "$i" "$at" 0 ""; done
    [ "$loadedcur" -eq 0 ] && echo "  ${C_DIM}none loaded - 'git undo --worktree' brings the latest into your worktree.${C_RESET}"
}

# Picker for the wip scope: pick a parked version and load it (saving any live edits as a
# new version first). Reads the WT_SHA[]/WCUR the caller loaded; $1=base, $2=cursor idx (@),
# $3=compact (toggleable in-session with 't', like the commit picker).
_ou_wip_picker() {
    local base="$1" at="$2" compact="${3:-0}" choice sel i n sn saved=0 tl
    n=${#WT_SHA[@]}; tl="${_OU_SDIR:-$(_ou_state_dir)}/wip/$base/timeline"
    while :; do
        echo "Parked working versions for ${C_DIM}${base:0:7}${C_RESET} ${C_MUTE}(newest first; ${C_AT}@${C_MUTE} = current worktree$(_ou_wip_legend "$compact" "$at"))${C_RESET}:"
        sn=0; SEL_IDX=()
        for (( i=n-1; i>=0; i-- )); do _ou_wip_hidden "$i" "$at" "$compact" && continue; sn=$(( sn + 1 )); SEL_IDX+=("$i"); _ou_wip_row "$i" "$at" 1 "$sn"; done
        if [ ! -t 0 ]; then echo; echo "${C_ERR}Not a terminal - re-run interactively to pick a version.${C_RESET}" >&2; return 2; fi
        read -r -p "${C_DIM}Load 1-${#SEL_IDX[@]}  ·  [t] toggle full/compact  ·  [q] quit:${C_RESET} " choice
        case "$choice" in
            t|T)      [ "$compact" -eq 1 ] && compact=0 || compact=1; echo; continue ;;
            q|Q|"")   echo "${C_DIM}Cancelled.${C_RESET}"; return 0 ;;
            *[!0-9]*) echo "${C_DIM}Invalid selection.${C_RESET}"; echo; continue ;;
        esac
        { [ "$choice" -ge 1 ] && [ "$choice" -le "${#SEL_IDX[@]}" ]; } || { echo "${C_DIM}Out of range.${C_RESET}"; echo; continue; }
        sel="${SEL_IDX[$(( choice - 1 ))]}"; break
    done
    [ "$sel" -eq "$at" ] && { echo "${C_DIM}Already loaded.${C_RESET}"; return 0; }
    _ou_wip_stamp_live "$tl" && saved=1          # never lose live edits
    git reset --hard --quiet HEAD 2>/dev/null
    _ou_wip_apply "${WT_SHA[$sel]}"
    WCUR="$sel"; _ou_wip_save_cursor "$base"
    if [ "$saved" -eq 1 ]; then
        echo "${C_OK}↜ Saved your current changes and loaded parked version $(_ou_wip_vnum "$sel") of $(_ou_wip_vtot)${C_RESET} ${C_DIM}(${WT_SHA[$sel]:0:7}).${C_RESET}"
    else
        echo "${C_OK}↜ Loaded parked version $(_ou_wip_vnum "$sel") of $(_ou_wip_vtot)${C_RESET} ${C_DIM}(${WT_SHA[$sel]:0:7}).${C_RESET}"
    fi
}

# `git goto <branch>` - `git switch` that PARKS your uncommitted work against the commit you
# leave and restores it when you return (it doesn't ride onto the new branch). Snapshots the
# dirty tree up front, switches, then (only on success) records the park
# against the commit you left and restores whatever was parked against the commit you land
# on. A bare `git goto` (no target) and any FAILED switch never park and never touch your
# tree beyond a guaranteed restore - so nothing is parked, lost, or announced unless you
# actually move. All switch args/options pass straight through.
git-goto() {
    local a; for a in "$@"; do case "$a" in -h|--help) _ou_help_goto; return 0 ;; esac; done
    # One git call for git-dir + HEAD sha + branch, so the state dir and the leaving id share
    # a single fork (not three). Unborn HEAD (no commit) falls through to a plain state-dir
    # lookup with no id - there's nothing to park.
    local base="" _o; local -a _p
    if _o=$(git rev-parse --git-dir HEAD --symbolic-full-name HEAD 2>/dev/null); then
        mapfile -t _p <<< "$_o"
        _OU_SDIR="${_p[0]}/git-undo-redo"
        local _br="${_p[2]#refs/heads/}"; [ "$_br" = "${_p[2]}" ] && _br=""   # 'HEAD' = detached
        _ou_wip_setid base "$_br" "${_p[1]}"
    else
        _OU_SDIR=$(_ou_state_dir) || { echo "${C_ERR}❌ Error: Not a git repository.${C_RESET}" >&2; return 1; }
    fi

    # A bare `git goto` (no target) is not a switch: forward to `git switch` for its own
    # usage/error and never park - no auto-stash when nothing is being moved.
    [ "$#" -eq 0 ] && { git switch; return $?; }

    local snap=""
    if [ -n "$base" ]; then
        # `git stash create` is BOTH the dirty check and the snapshot: empty = clean tracked
        # tree (nothing to park). We never reset without a verified snapshot in hand, so a
        # refused switch can't empty the worktree; snapshotting up front makes restore exact.
        snap=$(git stash create "git-undo-redo: goto-park @ ${base:0:12}" 2>/dev/null)
        [ -n "$snap" ] && git reset --hard --quiet HEAD 2>/dev/null
    fi

    git switch "$@"; local rc=$?

    if [ "$rc" -ne 0 ]; then
        # The switch didn't happen: silently restore the exact snapshot to the (unchanged)
        # branch. No park is recorded - a no-op move leaves no trace and no stash message.
        [ -n "$snap" ] && _ou_wip_apply "$snap"
        return "$rc"
    fi

    # Find where we landed - but only if there's anything parked to reason about. On a plain
    # clean switch with no parked work anywhere (the common case), skip the HEAD lookup.
    local dest=""
    { [ -n "$snap" ] || [ -d "${_OU_SDIR:-$(_ou_state_dir)}/wip" ]; } && _ou_wip_setcurid dest
    if [ -n "$dest" ] && [ "$dest" = "$base" ]; then
        # Same branch+commit - you didn't actually move (e.g. `git goto <current-branch>`).
        # Put the work straight back, silently: record no park and announce nothing.
        [ -n "$snap" ] && _ou_wip_apply "$snap"
        return 0
    fi

    # Real move: record the park against the branch+commit we left (so --worktree history has it)
    # and bring back (announcing) whatever was parked against the branch+commit we landed on.
    # Reading dest fresh post-switch is what keeps `git goto -c newbranch` (new branch, same
    # commit) from pulling back the work left on the old branch.
    if [ -n "$snap" ]; then
        _ou_wip_park "$base" "$snap"
    elif [ -n "$base" ] && [ -s "${_OU_SDIR:-$(_ou_state_dir)}/wip/$base/timeline" ]; then
        _ou_wip_park "$base" clean   # left clean, but this commit had parked work: record the clean state
    fi
    [ -n "$dest" ] && _ou_wip_restore "$dest"
}

_ou_help_goto() {
    cat <<'EOF'
git goto - switch branches without the stash/pop dance.

Usage: git goto <branch> [<git switch options>]    (a thin wrapper around 'git switch')

It is exactly 'git switch', except you needn't commit or stash first. Before switching it
parks your dirty tracked files - staged AND unstaged - against the commit you are leaving
(so they leave the working tree); on arrival it brings back whatever you parked against the
commit you land on. Your work waits where you left it, not on the new branch - nothing is
lost, and your 'git stash' stack is never touched.

Parked work is kept per commit, so you can leave changes against several commits and each
set returns where you left it. Untracked files are left alone (they travel with the
switch as usual). All 'git switch' options and arguments pass straight through.

  -h    Show this help. (Use -h, not --help, which git intercepts.)
EOF
    # 'git goto' is a thin wrapper around 'git switch', so show git's own option reference
    # too - relabeled to read as 'goto' so it's a seamless, always-current reference.
    echo
    echo "Options (forwarded to 'git switch', shown as 'goto'):"
    git switch -h 2>&1 | sed -e 's/git switch/git goto/g' -e 's/switch to/go to/g' -e 's/\bswitch\b/goto/g' -e 's/\bSwitch\b/Goto/g'
    return 0
}

# Render the status summary - where HEAD is, plus how many undo/redo steps remain - for
# the given scope. Read-only; backs `git undo --status` / `git redo --status` (-g/-e/-n).
_ou_status_show() {
    local mode="$1" branch d last
    if [ "$mode" = "global" ]; then
        _ou_global_derive readonly || { echo "${C_DIM}No history recorded yet.${C_RESET}"; return 0; }
        last=$(( ${#GL_SHA[@]} - 1 ))
        echo "${C_MUTE}HEAD is at:${C_RESET} $(_ou_short)"
        if [ "$GCUR" -eq 0 ] && [ "$last" -eq 0 ]; then
            echo "${C_DIM}Nothing to undo or redo globally yet - this is the only tracked state.${C_RESET}"
        else
            echo "${C_MUTE}Available globally (all operations, in order)${C_RESET} $(_ou_global_meter)"
        fi
    elif [ "$mode" = "navigation" ]; then
        _ou_nav_sync || return 1
        last=$(( ${#NV_SHA[@]} - 1 ))
        echo "${C_MUTE}HEAD is at:${C_RESET} $(_ou_short)  ${C_MUTE}on${C_RESET} ${C_REDO}$(_ou_nav_where "$NCUR")${C_RESET}"
        if [ "$NCUR" -eq 0 ] && [ "$last" -eq 0 ]; then
            echo "${C_DIM}No branch navigation to go back or forward through yet - this is the only tracked position.${C_RESET}"
        else
            echo "${C_MUTE}Branch navigation${C_RESET} $(_ou_nav_meter)"
        fi
    else
        branch=$(_ou_branch)
        if [ -z "$branch" ]; then
            echo "${C_ERR}❌ The edit log is per-branch, but HEAD is detached.${C_RESET}"
            echo "   Use 'git back --status' for the navigation log."
            return 1
        fi
        d=$(_ou_local_dir)            || return 1
        _ou_local_sync "$d" "$branch" || return 1
        last=$(( ${#LT_SHA[@]} - 1 ))
        echo "${C_MUTE}On branch${C_RESET} ${C_REDO}$branch${C_RESET}${C_MUTE}, HEAD is at:${C_RESET} $(_ou_short)"
        if [ "$LCUR" -eq 0 ] && [ "$last" -eq 0 ]; then
            echo "${C_DIM}No edits to undo or redo on $branch yet.${C_RESET}"
        else
            echo "${C_MUTE}Available on this branch${C_RESET} $(_ou_local_meter)"
        fi
    fi
}

# A prime anchor (the internal kind) is shown as its underlying operation kind plus the
# resume mark, e.g. "↻ commit" / "↻ checkout" - the op you carried on from, marked as the
# resume point (not the bare word "prime"). The underlying kind is the real entry sharing
# the prime's sha. $1 = index into TL_SHA/TL_KIND; echoes the bare kind (callers add ↻).
_ou_prime_kind() {
    local i="$1" sha="${TL_SHA[$1]}" j
    for (( j=0; j<${#TL_SHA[@]}; j++ )); do
        if [ "$j" -ne "$i" ] && [ "${TL_SHA[j]}" = "$sha" ] && [ "${TL_KIND[j]}" != prime ]; then
            [ "${TL_KIND[j]}" = floor ] && printf 'base' || printf '%s' "${TL_KIND[j]}"; return 0
        fi
    done
    printf 'commit'   # fallback: the real entry isn't in view (shouldn't happen)
}

# The log's leading "@" column, with relative distance: "@" at the cursor (green), else the
# step count away in subdued grey - a glance gives you the N for `git undo N` / `git redo N`
# (or back/forward N) without competing with the row's own colors. The "@" is indented (" @")
# so it stands out as the anchor; the numbers are flush-left (the offset reads as secondary)
# but the content column stays aligned. Distance is the true index gap (what N actually counts),
# so it's unaffected by compact hiding primes. A cursor of -1 (a worktree log with nothing
# loaded) yields a blank column. Width 2.
_ou_rel_mark() {
    local i="$1" cur="$2" lbl pad="  "
    [ "$cur" -lt 0 ] && { printf '  '; return; }
    [ "$i" -eq "$cur" ] && { printf ' %s@%s' "$C_AT" "$C_RESET"; return; }
    [ "$i" -gt "$cur" ] && lbl=$(( i - cur )) || lbl=$(( cur - i ))
    printf '%s%s%s%s' "$C_DIM" "$lbl" "$C_RESET" "${pad:${#lbl}}"
}

# Print the oplog (reads TL_SHA/TL_KIND/CUR, so the caller loads whichever log to
# show). $1=compact (hide prime rows except the cursor's); $2=numbered (prepend
# 1..N selection numbers and fill SEL_IDX, for interactive pick); $3=title.
_ou_oplog_print() {
    local compact="$1" numbered="$2" title="${3:-Edit log}" navmode="${4:-0}" i kind mark n=0 h u rest
    SEL_IDX=()

    # Resolve "<shortsha> <subject>" for every distinct sha in chunked batches
    # (one `git log` per ~256 shas) instead of one `git log` per row, so
    # printing stays fast even on a long, fully-retained oplog.
    declare -A SUBJ seen
    local batch=()
    for h in "${TL_SHA[@]}"; do
        [ -n "${seen[$h]:-}" ] && continue
        seen["$h"]=1
        batch+=("$h")
        if [ "${#batch[@]}" -ge 256 ]; then
            while IFS=$'\t' read -r u rest; do SUBJ["$u"]="$rest"; done \
                < <(git log --no-walk=unsorted --format='%H%x09%h %s' "${batch[@]}" 2>/dev/null)
            batch=()
        fi
    done
    if [ "${#batch[@]}" -gt 0 ]; then
        while IFS=$'\t' read -r u rest; do SUBJ["$u"]="$rest"; done \
            < <(git log --no-walk=unsorted --format='%H%x09%h %s' "${batch[@]}" 2>/dev/null)
    fi

    local _hp=0 _i   # legend only when a resume point is actually shown (compact hides all but the cursor's)
    for (( _i=0; _i<${#TL_KIND[@]}; _i++ )); do
        [ "${TL_KIND[_i]}" = prime ] || continue
        { [ "$compact" -ne 1 ] || [ "$_i" -eq "$CUR" ]; } && { _hp=1; break; }
    done
    local legend="${C_AT}@${C_MUTE} = current position"
    [ "$_hp" -eq 1 ] && legend="$legend, ${C_RESUME}↻${C_MUTE} = resume point"
    echo "$title ${C_MUTE}(newest first; $legend)${C_RESET}:"
    local pad="         " kpad kcol mark subj uk   # pad = 9 spaces (kind column width)
    for (( i=${#TL_SHA[@]}-1; i>=0; i-- )); do
        kind="${TL_KIND[i]}"
        [ "$kind" = floor ] && kind=base            # the branch-point floor: where this branch was created
        if [ "$compact" -eq 1 ] && [ "$kind" = "prime" ] && [ "$i" -ne "$CUR" ]; then
            continue
        fi
        # @ marks the cursor (green); kind is pink at the cursor, cyan for a resume
        # point, amber otherwise - so a resume point reads apart from the purple branch.
        if [ "$i" -eq "$CUR" ]; then mark=" ${C_AT}@${C_RESET}"; kcol="$C_UNDO"
        elif [ "$kind" = "prime" ];  then mark="  "; kcol="$C_RESUME"
        else                              mark="  "; kcol="$C_KIND"; fi
        if [ "$kind" = "prime" ]; then             # the resumed-from op marked as a resume point, e.g. "↻ commit"
            uk="$(_ou_prime_kind "$i")"; kpad="↻ $uk${pad:$(( ${#uk} + 2 ))}"
        else
            kpad="$kind${pad:${#kind}}"            # left-justify to 9 (no color in the width)
        fi
        subj="${SUBJ[${TL_SHA[i]}]:-${TL_SHA[i]:0:7}}"
        if [ "$navmode" -eq 1 ]; then          # nav rows show the position, not just the commit
            if [ -n "${TL_REF[i]:-}" ]; then subj="${C_REDO}${TL_REF[i]}${C_RESET} ${C_DIM}(at ${subj})${C_RESET}"
            else subj="${C_DIM}detached${C_RESET} ${subj}"; fi
        fi
        if [ "$numbered" -eq 1 ]; then
            n=$(( n + 1 )); SEL_IDX+=("$i")
            printf '%s %2d) %s%s%s %s\n' "$mark" "$n" "$kcol" "$kpad" "$C_RESET" "$subj"
        else
            printf '%s  %s%s%s %s\n' "$(_ou_rel_mark "$i" "$CUR")" "$kcol" "$kpad" "$C_RESET" "$subj"
        fi
    done
    # Below a root branch's oldest edit (its genesis IS the repo's first commit) lies the
    # empty repo - a real floor you can't undo to. Show it dim and index-less so the edit
    # log reads symmetric with a feature branch's reachable `base`, while the styling makes
    # clear it isn't a selectable point. Only for the edit log (navmode 0) at a true,
    # parentless genesis - never below a `base`, which is already that branch's floor.
    if [ "$navmode" -eq 0 ] && [ "${#TL_SHA[@]}" -gt 0 ] && [ "${TL_KIND[0]}" != floor ] \
       && ! git rev-parse --verify --quiet "${TL_SHA[0]}^" >/dev/null 2>&1; then
        printf '    %sbase     empty repo - nothing earlier to undo to%s\n' "$C_DIM" "$C_RESET"
    fi
}

# Interactive: show the oplog and drop straight to a chosen point. A cursor move
# (restores the state, never detaches), not a new operation. $1=initial view
# (0=full / 1=compact, toggleable in-session with 't'); $2=scope (global|local;
# decides how the jump is applied and saved); $3=title. The caller has already
# loaded the chosen log into TL_SHA/TL_KIND/CUR.
_ou_oplog_interactive() {
    local compact="$1" scope="${2:-edit}" title="${3:-Edit log}" choice idx navmode=0
    { [ "$scope" = "navigation" ] || [ "$scope" = "global" ]; } && navmode=1
    while :; do
        _ou_oplog_print "$compact" 1 "$title" "$navmode"
        if [ ! -t 0 ]; then
            echo
            echo "${C_ERR}Not a terminal - re-run interactively to pick a point.${C_RESET}" >&2
            return 2
        fi
        read -r -p "${C_DIM}Drop to 1-${#SEL_IDX[@]}  ·  [t] toggle full/compact  ·  [q] quit:${C_RESET} " choice
        case "$choice" in
            t|T)         [ "$compact" -eq 1 ] && compact=0 || compact=1; echo; continue ;;
            q|Q|"")      echo "${C_DIM}Cancelled.${C_RESET}"; return 0 ;;
            *[!0-9]*)    echo "${C_DIM}Invalid selection.${C_RESET}"; echo; continue ;;
        esac
        if [ "$choice" -lt 1 ] || [ "$choice" -gt "${#SEL_IDX[@]}" ]; then
            echo "${C_DIM}Out of range.${C_RESET}"; echo; continue
        fi
        idx="${SEL_IDX[$((choice - 1))]}"
        break
    done
    [ "$idx" -eq "$CUR" ] && { echo "${C_DIM}Already here.${C_RESET}"; return 0; }
    _ou_wip_before || return 1   # park dirty work (only now that a jump is chosen); restored at the landing
    if [ "$scope" = "global" ]; then
        _ou_global_walk "$idx" || { _ou_restore_failed; _ou_wip_after; return 1; }   # global: walk to the point
        echo "${C_OK}→ Dropped to${C_RESET} $(_ou_short)  $(_ou_global_meter)"
    elif [ "$scope" = "navigation" ]; then
        _ou_nav_goto "$idx" git-undo || { _ou_restore_failed; _ou_wip_after; return 1; }   # nav: one atomic checkout
        echo "${C_OK}→ Dropped to${C_RESET} on $(_ou_nav_where "$idx")  $(_ou_nav_meter)"
    else
        OU_ACTION="git-undo" _ou_local_restore "${TL_SHA[$idx]}" || { _ou_restore_failed; _ou_wip_after; return 1; }
        CUR="$idx"                                          # edit: jump straight there
        printf '%s\n' "$idx" > "$(_ou_local_dir)/cursor"   # timeline unchanged; move cursor only
        echo "${C_OK}→ Dropped to${C_RESET} $(_ou_short)  $(_ou_meter)"
    fi
    _ou_wip_after
}

# Show a log for a scope: print it, or (interactive) open the picker. $1=mode
# (global|local), $2=compact (0/1 initial view), $3=interactive (0/1). Loads the
# chosen log into TL_SHA/TL_KIND/CUR. Shared by `git undo --log` / `--interactive`
# (and the redo equivalents) so they honor -g/-e/-n and undoredo.scope identically.
_ou_show() {
    local mode="$1" compact="$2" interactive="$3" branch d
    if [ "$mode" = "global" ]; then
        _ou_global_derive readonly || { echo "${C_DIM}No history recorded yet.${C_RESET}"; return 0; }
        TL_SHA=("${GL_SHA[@]}"); TL_KIND=("${GL_KIND[@]}"); TL_REF=("${GL_REF[@]}"); CUR=$GCUR
        if [ "$interactive" -eq 1 ]; then
            _ou_oplog_interactive "$compact" global "Global operation log"
        else
            _ou_oplog_print "$compact" 0 "Global operation log" 1
        fi
    elif [ "$mode" = "navigation" ]; then
        _ou_nav_sync || return 1
        [ "${#NV_SHA[@]}" -gt 0 ] || { echo "${C_DIM}No navigation recorded yet.${C_RESET}"; return 0; }
        TL_SHA=("${NV_SHA[@]}"); TL_KIND=("${NV_KIND[@]}"); TL_REF=("${NV_REF[@]}"); CUR=$NCUR
        if [ "$interactive" -eq 1 ]; then
            _ou_oplog_interactive "$compact" navigation "Navigation log"
        else
            _ou_oplog_print "$compact" 0 "Navigation log" 1
        fi
    else
        branch=$(_ou_branch)
        if [ -z "$branch" ]; then
            echo "${C_ERR}❌ The edit log is per-branch, but HEAD is detached.${C_RESET}"
            echo "   Use the navigation log instead (e.g. 'git back --log')."
            return 1
        fi
        d=$(_ou_local_dir)            || return 1
        _ou_local_sync "$d" "$branch" || return 1
        [ "${#LT_SHA[@]}" -gt 0 ] || { echo "${C_DIM}No edits recorded for $branch yet.${C_RESET}"; return 0; }
        TL_SHA=("${LT_SHA[@]}"); TL_KIND=("${LT_KIND[@]}"); TL_REF=(); CUR=$LCUR
        if [ "$interactive" -eq 1 ]; then
            _ou_oplog_interactive "$compact" edit "Edit log for '$branch'"
        else
            _ou_oplog_print "$compact" 0 "Edit log for '$branch'"
        fi
    fi
}


# Reset the oplog: drop the tracked state (global timeline + cursor, all per-branch
# logs, keep-refs) so the next command rebuilds it cleanly from git's reflog. This
# is a REBUILD, not a wipe - re-deriving from the reflog is exactly how the tool is
# meant to work, so recent history stitches back in; what's dropped is accumulated
# tracking older than the reflog, prime anchors, and any wedged state. Does NOT touch
# your commits or working tree. Exposed as `git undo --reset` (and `git redo --reset`).
_ou_reset() {
    _ou_require_repo || return 1
    local sdir r had=0
    sdir=$(_ou_state_dir) || return 1

    { [ -e "$sdir/nav/timeline" ] || [ -d "$sdir/local" ] || [ -e "$sdir/timeline" ] || [ -d "$sdir/wip" ]; } && had=1
    # Drop the oplog keep-refs AND the wip snapshot refs (parked working-tree versions from
    # `git goto` / dirty undo-redo), so --reset is a full clear of THIS worktree's tracked state.
    # keep/wipkeep refs live in the SHARED (common) ref store, but each worktree's logs are its
    # own (under its `--git-dir`); so we delete only the refs whose sha appears in this worktree's
    # timelines - never another linked worktree's gc-protection. (For a single worktree this is
    # every ref, identical to before.) Timelines are append-only, so they name every sha that
    # ever got a keep/wipkeep ref here.
    local f sha; declare -A _mine=()
    for f in "$sdir/nav/timeline" "$sdir/timeline" "$sdir"/local/*/timeline "$sdir"/wip/*/timeline; do
        [ -f "$f" ] || continue
        while IFS=$'\t' read -r sha _; do [ -n "$sha" ] && [ "$sha" != clean ] && _mine["$sha"]=1; done < "$f"
    done
    local refname objsha out=""
    while read -r refname objsha; do
        [ -n "${_mine[$objsha]:-}" ] && out+="delete $refname"$'\n'
    done < <(git for-each-ref --format='%(refname) %(objectname)' refs/git-undo-redo/keep/ refs/git-undo-redo/wipkeep/ 2>/dev/null)
    [ -n "$out" ] && printf '%s' "$out" | git update-ref --stdin 2>/dev/null
    rm -rf "$sdir/nav" "$sdir/local" "$sdir/global" "$sdir/wip" 2>/dev/null   # nav + edit + global cursor + parked wip
    rm -f "$sdir/timeline" "$sdir/cursor" 2>/dev/null   # vestigial pre-split global log

    if [ "$had" -eq 0 ]; then
        echo "${C_DIM}Nothing to reset - no oplog exists yet.${C_RESET}"
        return 0
    fi
    echo "${C_OK}🔄 Reset the oplog.${C_RESET} Both the navigation and edit logs rebuild from git's reflog on the next command; your commits and files are untouched."
    echo "${C_DIM}Note: anything older than your reflog (and any redo trail ahead of you) isn't re-derived, and its"
    echo "      gc protection is dropped - git's reflog keeps it until expiry. Parked working-tree versions"
    echo "      ('git goto' / 'git undo --worktree') are also cleared; your current working tree is left as-is.${C_RESET}"
}

# Point users of the old standalone commands at their new flag homes. The oplog and
# opstatus commands were folded into undo/redo as --log and --status; this fires only
# for a lingering old symlink or the umbrella form, since the installer no longer makes
# git-oplog / git-opstatus.
_ou_moved_hint() {
    case "$1" in
        *oplog)    echo "${C_DIM}'$1' is now${C_RESET} git undo --log ${C_DIM}('git back --log' for navigation; -i to pick).${C_RESET}" >&2 ;;
        *opstatus) echo "${C_DIM}'$1' is now${C_RESET} git undo --status ${C_DIM}('git back --status' for navigation).${C_RESET}" >&2 ;;
    esac
    return 2
}

# ---- CLI dispatcher: runs only when executed, not when sourced -------
# Multi-call binary: symlink (or copy) this file to git-undo, git-redo, git-take, git-goto,
# git-back, git-forward on your PATH; each dispatches by its invoked name. The umbrella name
# (git-undo-redo) also takes the command as its first arg.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    _ou_load_config     # one git-config read for all undoredo.* keys
    _ou_colors          # set up ANSI colors once (no-op when piped / disabled)
    case "$(basename "$0")" in
        git-undo)               git-undo "$@" ;;
        git-redo)               git-redo "$@" ;;
        git-take)               git-take "$@" ;;
        git-goto)               git-goto "$@" ;;
        git-back)               git-back "$@" ;;
        git-forward)            git-forward "$@" ;;
        git-oplog|git-opstatus) _ou_moved_hint "$(basename "$0")" ;;   # removed: see hint
        *)
            case "${1:-help}" in
                undo)           shift; git-undo "$@" ;;
                redo)           shift; git-redo "$@" ;;
                take)           shift; git-take "$@" ;;
                goto)           shift; git-goto "$@" ;;
                back)           shift; git-back "$@" ;;
                forward)        shift; git-forward "$@" ;;
                oplog|opstatus) _ou_moved_hint "git $1" ;;             # removed: see hint
                reset|--reset)  _ou_reset ;;
                help|-h|--help) _ou_usage ;;
                *)              echo "${C_ERR}Unknown command: $1${C_RESET}" >&2; echo >&2; _ou_usage >&2; exit 2 ;;
            esac
            ;;
    esac
fi
